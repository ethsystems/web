---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  activeSection?: 'approaches' | 'patterns' | 'vendors' | 'domains' | 'jurisdictions' | 'faq' | 'glossary' | null;
}
const { title = 'IPTF Guide', description = '', activeSection = null } = Astro.props;
const base = import.meta.env.BASE_URL;

const navItems = [
  { label: 'Case Studies', href: `/approaches`, key: 'approaches' },
  { label: 'Patterns', href: `/patterns`, key: 'patterns' },
  { label: 'Vendors', href: `/vendors`, key: 'vendors' },
  { label: 'Domains', href: `/domains`, key: 'domains' },
  { label: 'FAQ', href: `/faq`, key: 'faq' },
  { label: 'Glossary', href: `/glossary`, key: 'glossary' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — IPTF Guide</title>
    {description && <meta name="description" content={description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: 'Inter', -apple-system, sans-serif;
        background: #08080a;
        color: #d4d4d8;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        opacity: 0.03;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 200px;
      }
      code {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.85em;
        background: #1c1c20;
        padding: 1px 5px;
        border-radius: 4px;
        color: #d4d4d8;
      }

      /* ── Top nav ── */
      .guide-nav {
        position: fixed; top: 0; left: 0; right: 0; z-index: 100;
        background: rgba(8,8,10,0.85);
        backdrop-filter: blur(24px) saturate(180%);
        -webkit-backdrop-filter: blur(24px) saturate(180%);
        border-bottom: 1px solid rgba(255,255,255,0.05);
      }
      .guide-nav-inner {
        max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;
        height: 56px; display: flex; align-items: center; gap: 1.5rem;
      }
      .guide-nav-brand {
        display: flex; align-items: center; gap: 10px;
        text-decoration: none; color: white;
        font-weight: 700; font-size: 0.85rem; letter-spacing: 0.1em;
        flex-shrink: 0;
      }
      .guide-nav-mark {
        width: 18px; height: 18px;
        background: linear-gradient(135deg, #818cf8, #6366f1);
        transform: rotate(45deg); border-radius: 3px;
      }
      .guide-nav-links {
        display: flex; align-items: center; gap: 1.25rem;
        overflow-x: auto; flex: 1; justify-content: flex-end;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }
      .guide-nav-links::-webkit-scrollbar { display: none; }
      .guide-nav-link {
        text-decoration: none; font-size: 0.78rem; font-weight: 500;
        letter-spacing: 0.01em; white-space: nowrap; transition: color 0.15s;
        color: #71717a;
      }
      .guide-nav-link:hover { color: white; }
      .guide-nav-link.active { color: white; }
      .guide-nav-link.guide-nav-ext { color: #52525b; }
      .guide-nav-sep {
        width: 1px; height: 16px;
        background: rgba(255,255,255,0.08);
        flex-shrink: 0;
      }
      @media (max-width: 900px) {
        .guide-nav-links { justify-content: flex-start; }
      }
      @media (max-width: 640px) {
        .guide-nav-inner { padding: 0 1rem; gap: 1rem; }
        .guide-nav-links { gap: 1rem; justify-content: flex-start; }
        .guide-nav-sep, .guide-nav-ext { display: none; }
        .guide-nav-link { font-size: 0.75rem; }
      }
    </style>
  </head>
  <body>
    <!-- Top nav -->
    <header class="guide-nav">
      <div class="guide-nav-inner">
        <a href={`/`} class="guide-nav-brand">
          <div class="guide-nav-mark"></div>
          IPTF
        </a>
        <nav class="guide-nav-links">
          {navItems.map(item => (
            <a href={item.href} class={`guide-nav-link ${activeSection === item.key ? 'active' : ''}`}>
              {item.label}
            </a>
          ))}
          <span class="guide-nav-sep"></span>
          <a href="/about" class="guide-nav-link guide-nav-ext">About</a>
          <a href="https://iptf.ethereum.org/blog/" class="guide-nav-link guide-nav-ext">Blog</a>
        </nav>
      </div>
    </header>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer style="padding:2.5rem 2rem; background:#08080a; border-top:1px solid rgba(255,255,255,0.05);">
      <div style="max-width:1200px; margin:0 auto; display:flex; align-items:center; justify-content:space-between;">
        <div style="display:flex; align-items:center; gap:8px; font-size:0.75rem; color:#52525b;">
          <div style="width:12px; height:12px; background:#27272a; transform:rotate(45deg); border-radius:2px;"></div>
          IPTF &middot; Ethereum Foundation &middot; 2026
        </div>
        <nav style="display:flex; gap:1.5rem;">
          <a href="/about" style="font-size:0.75rem; color:#52525b; text-decoration:none; transition:color 0.15s;">About</a>
          <a href="/explore/galaxy" style="font-size:0.75rem; color:#52525b; text-decoration:none; transition:color 0.15s;">Explorer</a>
          <a href="https://github.com/ethereum/iptf-map" style="font-size:0.75rem; color:#52525b; text-decoration:none; transition:color 0.15s;">GitHub</a>
          <a href="https://iptf.ethereum.org/blog/" style="font-size:0.75rem; color:#52525b; text-decoration:none; transition:color 0.15s;">Blog</a>
          <a href="mailto:iptf@ethereum.org" style="font-size:0.75rem; color:#52525b; text-decoration:none; transition:color 0.15s;">Contact</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
