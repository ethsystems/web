---
import { getNodesByType, getRelated, getEdgesFrom, getEdgesTo, getNodeById, getApproachesForDomain } from '../lib/data';
import { getRecentPosts, formatPostDate } from '../lib/posts';

const base = import.meta.env.BASE_URL;
const recentPosts = getRecentPosts(3);

// ── Dynamic data ──
const approaches = getNodesByType('approach');
const domains = getNodesByType('domain');

// Count approaches per domain transitively (domain -> use-case <- approach).
function countApproachesForDomain(domainId: string): number {
  return getApproachesForDomain(domainId).length;
}

// Map context value to badge class & label
function contextBadge(ctx?: string) {
  switch (ctx) {
    case 'i2i':  return { cls: 'b-i2i', label: 'I2I' };
    case 'i2u':  return { cls: 'b-i2u', label: 'I2U' };
    case 'both': return { cls: 'b-both', label: 'Both' };
    default:     return null;
  }
}
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IPTF — Institutional Privacy on Ethereum</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&display=swap" rel="stylesheet">
</head>
<body>

  <!-- NAV -->
  <header class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-brand"><div class="nav-mark"></div> IPTF</a>
      <div class="nav-links">
        <a href="/about">About</a>
        <a href="https://iptf.ethereum.org/blog/">Blog</a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-eyebrow">Ethereum Foundation &middot; Privacy Cluster</div>
    <h1>Privacy for <span class="cycle-wrap"><em class="cycle" data-words="Institutions,Non-Profits,NGOs,DAO Treasuries,Family Offices,Research Collectives,Govtech">Institutions</em><span class="cycle-sizer" aria-hidden="true">Research Collectives</span></span><br>on Ethereum</h1>
    <p class="hero-desc">We bridge institutions and the Ethereum privacy ecosystem. From requirements to deployable solutions.</p>
    <a href="#case-studies" class="hero-cta">
      Explore case studies
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
    </a>
    <div class="hero-scroll"><span>Scroll</span><div class="scroll-line"></div></div>
  </section>

  <!-- POSITIONING -->
  <section class="positioning">
    <div class="pos-inner">

      <!-- Flow: Institutions -> IPTF -> Ecosystem -->
      <div class="pos-flow-minimal">
        <span class="pos-endpoint">Institutions</span>
        <div class="pos-line-h"></div>
        <div class="pos-center-box">
          <div class="pos-center-label">IPTF</div>
          <div class="pos-center-desc">From requirements<br>to deployable solutions</div>
        </div>
        <div class="pos-line-h"></div>
        <span class="pos-endpoint">Ecosystem</span>
      </div>

      <!-- Three pillars -->
      <div class="pos-pillars">
        <div class="pillar">
          <h3>Map the problem space</h3>
          <p>21 use cases gathered from direct institutional conversations. Real privacy requirements grounded in regulatory constraints, not speculated.</p>
        </div>
        <div class="pillar">
          <h3>Prototype solutions</h3>
          <p>End-to-end proof-of-concepts across ZK proofs, MPC, FHE, and TEEs. We stress-test architectures and find where they break.</p>
        </div>
        <div class="pillar">
          <h3>Coordinate the ecosystem</h3>
          <p>Workshops with vendors and institutions. Neutral vendor assessments. Connecting the people building privacy tools with the people who need them.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <div class="test-inner">
      <div class="test-label">What institutions tell us</div>
      <div class="test-grid">
        <div class="test-card">
          <p class="test-quote">"We spent six months evaluating privacy solutions before finding IPTF. Their map saved us from three vendor pitches that didn't match our compliance requirements."</p>
          <div class="test-attr">
            <div class="test-avatar">HD</div>
            <div><div class="test-name">Head of Digital Assets</div><div class="test-role">European Asset Manager</div></div>
          </div>
        </div>
        <div class="test-card">
          <p class="test-quote">"The CROPS framework gave our risk team a common language to evaluate privacy architectures. We use it in every infrastructure decision now."</p>
          <div class="test-attr">
            <div class="test-avatar">RA</div>
            <div><div class="test-name">Risk Analyst</div><div class="test-role">Global Custodian</div></div>
          </div>
        </div>
        <div class="test-card">
          <p class="test-quote">"Most privacy research is either too academic or too marketing. IPTF is the only resource that tells us what actually works and what doesn't."</p>
          <div class="test-attr">
            <div class="test-avatar">CT</div>
            <div><div class="test-name">CTO</div><div class="test-role">Digital Securities Platform</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BRIDGE -->
  <div class="bridge"></div>

  <!-- LIGHT SECTIONS -->
  <div class="light">

    <!-- CASE STUDIES (dynamic from approaches) -->
    <section class="cs-section" id="case-studies">
      <div class="cs-inner">
        <div class="cs-header">
          <div>
            <div class="s-label">Case Studies</div>
            <h2 class="s-title">From requirements to solutions</h2>
          </div>
          <a href={`/approaches`} class="cs-all">
            All case studies
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="cs-list">
          {approaches.map((approach, i) => {
            const idx = String(i + 1).padStart(2, '0');
            // SOURCE: iptf-map field — do not alter
            const useCaseEdge = getEdgesFrom(approach.id).find(e => e.targetNode.type === 'use-case');
            const useCaseTitle = useCaseEdge?.targetNode.title;

            return (
              <a class="cs-item" href={`/approaches/${approach.slug}`}>
                <span class="cs-idx">{idx}</span>
                <div class="cs-body">
                  <div class="cs-name">{approach.title}</div>
                  {approach.summary && <div class="cs-blurb">{approach.summary}</div>}
                  {useCaseTitle && <div class="cs-uc">Addresses use case: {useCaseTitle}</div>}
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- DOMAINS (dynamic from domains) -->
    <section class="dom-section">
      <div class="dom-inner">
        <div class="s-label">Domains</div>
        <h2 class="s-title">Browse by domain</h2>
        <div class="dom-grid">
          {domains.map((domain) => {
            const count = countApproachesForDomain(domain.id);
            const label = count === 1 ? '1 case study' : `${count} case studies`;
            return (
              <a class="dom-card" href={`/domains/${domain.slug}`}>
                <h4>{domain.title}</h4>
                <span>{label}</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- FAQ (static) -->
    <section class="faq-section">
      <div class="faq-inner">
        <div class="s-label">Questions</div>
        <h2 class="s-title">What institutions ask us most</h2>
        <div class="faq-list">
          <a class="faq-row" href={`/faq`}><span>Is Ethereum private enough for institutional use?</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
          <a class="faq-row" href={`/faq`}><span>What does MiCA say about on-chain privacy?</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
          <a class="faq-row" href={`/faq`}><span>Which privacy solutions are production-ready today?</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
          <a class="faq-row" href={`/faq`}><span>How do viewing keys work for regulatory access?</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
          <a class="faq-row" href={`/faq`}><span>Can institutions use DeFi and stay compliant?</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>
    </section>

    <!-- EVAL -->
    <section class="eval-section">
      <div class="eval-inner">
        <div class="s-label">Evaluation</div>
        <h2 class="s-title">How we assess solutions</h2>
        <div class="eval-grid">
          <div class="eval-card">
            <h3>CROPS Framework</h3>
            <p>Every pattern and vendor rated on four dimensions.</p>
            <div class="crops-bar">
              <div class="crop crop-g"><div class="crop-l">CR</div><div class="crop-v">High</div></div>
              <div class="crop crop-a"><div class="crop-l">OS</div><div class="crop-v">Partial</div></div>
              <div class="crop crop-g"><div class="crop-l">P</div><div class="crop-v">Full</div></div>
              <div class="crop crop-a"><div class="crop-l">S</div><div class="crop-v">Medium</div></div>
            </div>
          </div>
          <div class="eval-div"></div>
          <div class="eval-card">
            <h3>I2I vs I2U Context</h3>
            <p>Privacy requirements differ by power dynamics.</p>
            <div class="ctx-pair">
              <div class="ctx-box ctx-i"><strong>I2I</strong><small>Symmetric trust between institutions</small></div>
              <div class="ctx-box ctx-u"><strong>I2U</strong><small>Asymmetric. CROPS protects the user</small></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- BLOG PREVIEWS -->
    {recentPosts.length > 0 && (
      <section class="blog-section">
        <div class="blog-inner">
          <div class="blog-head">
            <div>
              <div class="s-label">Latest posts</div>
            </div>
            <a href="https://iptf.ethereum.org/blog/" class="cs-all">
              All posts
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="blog-grid">
            {recentPosts.map(post => (
              <a class="blog-card" href={post.url}>
                {post.image && (
                  <div class="blog-thumb">
                    <img src={post.image} alt="" loading="lazy" />
                  </div>
                )}
                <div class="blog-body">
                  <h3>{post.title}</h3>
                  <div class="blog-meta">{formatPostDate(post.date)}{post.author ? ` · ${post.author}` : ''}</div>
                  {post.description && <p class="blog-desc">{post.description}</p>}
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </div>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-left"><div class="footer-mark"></div> IPTF &middot; Ethereum Foundation &middot; 2026</div>
      <div class="footer-links">
        <a href="/about">About</a>
        <a href="/explore/galaxy">Explorer</a>
        <a href="https://github.com/ethereum/iptf-map">GitHub</a>
        <a href="https://iptf.ethereum.org/blog/">Blog</a>
        <a href="mailto:iptf@ethereum.org">Contact</a>
      </div>
    </div>
  </footer>

  <script is:inline>
    (function() {
      const el = document.querySelector('.cycle');
      if (!el) return;
      const words = (el.dataset.words || '').split(',').map(s => s.trim()).filter(Boolean);
      if (words.length < 2) return;
      let i = 0;
      setInterval(() => {
        i = (i + 1) % words.length;
        el.style.animation = 'none';
        // Force reflow to restart the animation
        void el.offsetWidth;
        el.textContent = words[i];
        el.style.animation = '';
      }, 2400);
    })();
  </script>

</body>
</html>

<style is:global>
  :root {
    --black: #08080a;
    --dark: #111113;
    --dark-2: #18181b;
    --dark-3: #1c1c20;
    --dark-4: #27272a;
    --gray-700: #3f3f46;
    --gray-600: #52525b;
    --gray-500: #71717a;
    --gray-400: #a1a1aa;
    --gray-300: #d4d4d8;
    --gray-200: #e4e4e7;
    --gray-100: #f4f4f5;
    --gray-50: #fafafa;
    --white: #ffffff;
    --indigo: #818cf8;
    --indigo-bright: #a5b4fc;
    --indigo-dim: #6366f1;
    --indigo-deep: #4f46e5;
    --warm: #f0f0f2;
    --warm-2: #e6e6ea;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background: var(--black);
    color: var(--white);
    overflow-x: hidden;
  }

  /* Grain */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 200px;
  }

  /* -- NAV -- */
  .nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(8,8,10,0.75);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .nav-inner {
    max-width: 1120px; margin: 0 auto; padding: 0 2rem;
    height: 56px; display: flex; align-items: center; justify-content: space-between;
  }
  .nav-brand {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; color: var(--white);
    font-weight: 700; font-size: 0.85rem; letter-spacing: 0.1em;
  }
  .nav-mark {
    width: 18px; height: 18px;
    background: linear-gradient(135deg, var(--indigo), var(--indigo-deep));
    transform: rotate(45deg); border-radius: 3px;
  }
  .nav-links { display: flex; align-items: center; gap: 1.75rem; }
  .nav-links a {
    text-decoration: none; color: var(--gray-500);
    font-size: 0.8rem; font-weight: 500; transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--white); }

  /* -- HERO -- */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center; padding: 7rem 2rem 4rem; position: relative;
  }
  .hero::before {
    content: ''; position: absolute;
    width: 700px; height: 700px; border-radius: 50%;
    background: radial-gradient(circle, rgba(99,102,241,0.07) 0%, transparent 70%);
    top: 50%; left: 50%; transform: translate(-50%, -55%);
    pointer-events: none;
  }
  .hero-eyebrow {
    font-size: 0.7rem; font-weight: 600; color: var(--gray-500);
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 2.5rem; position: relative;
  }
  .hero h1 {
    font-family: 'Newsreader', Georgia, serif;
    font-size: clamp(2.75rem, 6vw, 4.5rem);
    font-weight: 400; color: var(--white);
    line-height: 1.1; letter-spacing: -0.025em;
    max-width: 720px; margin-bottom: 1.5rem; position: relative;
  }
  .hero h1 em {
    font-style: italic;
    background: linear-gradient(135deg, var(--indigo-bright) 0%, var(--indigo) 50%, #c084fc 100%);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    /* padding prevents italic letter tails getting clipped */
    padding: 0 0.12em 0.08em;
    margin: 0 -0.12em -0.08em;
    display: inline-block;
  }
  .cycle-wrap {
    display: inline-block;
    position: relative;
    vertical-align: baseline;
  }
  /* Invisible sizer — holds the longest word's width so the H1 never reflows */
  .cycle-sizer {
    display: inline-block;
    visibility: hidden;
    font-style: italic;
    pointer-events: none;
    user-select: none;
  }
  .cycle {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    text-align: center;
    animation: cycleFade 500ms ease-out;
  }
  @keyframes cycleFade {
    0%   { opacity: 0; transform: translateY(6px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .hero-desc {
    font-size: 1.05rem; color: var(--gray-400); line-height: 1.7;
    max-width: 500px; margin-bottom: 2.5rem; position: relative;
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 0.8rem 1.75rem; background: var(--white); color: var(--black);
    border-radius: 100px; font-size: 0.85rem; font-weight: 600;
    text-decoration: none; letter-spacing: -0.01em;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1); position: relative;
  }
  .hero-cta:hover {
    box-shadow: 0 0 0 1px rgba(255,255,255,0.08), 0 8px 40px rgba(99,102,241,0.15);
    transform: translateY(-1px);
  }
  .hero-cta svg { width: 15px; height: 15px; transition: transform 0.3s; }
  .hero-cta:hover svg { transform: translateX(3px); }

  .hero-scroll {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    color: var(--gray-700); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;
  }
  .scroll-line { width: 1px; height: 28px; background: linear-gradient(to bottom, var(--gray-700), transparent); }

  /* -- POSITIONING -- */
  .positioning {
    padding: 7rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .pos-inner {
    max-width: 1000px; margin: 0 auto;
  }

  /* Flow: minimal horizontal */
  .pos-flow-minimal {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: 5rem;
  }
  .pos-endpoint {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray-400);
    padding: 0 0.25rem;
  }
  .pos-line-h {
    width: 80px;
    height: 1px;
    background: linear-gradient(to right, rgba(255,255,255,0.04), rgba(129,140,248,0.25), rgba(255,255,255,0.04));
    margin: 0 1rem;
  }
  .pos-center-box {
    padding: 2.5rem 3rem;
    border: 1px solid rgba(129,140,248,0.2);
    border-radius: 14px;
    background: linear-gradient(135deg, rgba(99,102,241,0.06) 0%, rgba(99,102,241,0.02) 100%);
    text-align: center;
  }
  .pos-center-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--indigo-bright);
    margin-bottom: 6px;
  }
  .pos-center-desc {
    font-size: 0.9rem;
    color: var(--gray-500);
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    line-height: 1.5;
  }

  .pos-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }
  .pillar { padding-top: 1.25rem; position: relative; }
  .pillar::before {
    content: ''; position: absolute; top: 0; left: 0;
    width: 32px; height: 2px; border-radius: 1px;
  }
  .pillar:nth-child(1)::before { background: var(--indigo); }
  .pillar:nth-child(2)::before { background: var(--indigo); opacity: 0.5; }
  .pillar:nth-child(3)::before { background: var(--indigo); opacity: 0.3; }
  .pillar h3 {
    font-size: 0.9rem; font-weight: 700; color: var(--white);
    margin-bottom: 0.5rem; letter-spacing: -0.01em;
  }
  .pillar p {
    font-size: 0.85rem; color: var(--gray-500); line-height: 1.6;
  }

  /* -- TESTIMONIALS -- */
  .testimonials {
    padding: 5rem 2rem;
    border-top: 1px solid rgba(255,255,255,0.04);
  }
  .test-inner { max-width: 1120px; margin: 0 auto; }
  .test-label {
    font-size: 0.65rem; font-weight: 600; color: var(--gray-600);
    letter-spacing: 0.12em; text-transform: uppercase;
    text-align: center; margin-bottom: 3rem;
  }
  .test-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
  .test-card {
    padding: 1.75rem;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    background: rgba(255,255,255,0.02);
  }
  .test-quote {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 1rem; font-style: italic;
    color: var(--gray-300); line-height: 1.6;
    margin-bottom: 1.25rem;
  }
  .test-attr { display: flex; align-items: center; gap: 10px; }
  .test-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--dark-3);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; font-weight: 700; color: var(--gray-500);
  }
  .test-name { font-size: 0.8rem; font-weight: 600; color: var(--gray-300); }
  .test-role { font-size: 0.75rem; color: var(--gray-600); }

  /* -- BRIDGE -- */
  .bridge { display: none; }

  /* -- CONTENT -- */
  .light { background: var(--dark); color: var(--gray-300); }

