---
import Guide from './Guide.astro';
import { formatPostDate } from '../lib/posts';
import type { Post } from '../lib/posts';

interface Props {
  post: Post;
}
const { post } = Astro.props;

// Reading-time estimate (Jekyll convention: words / 200, min 1 minute)
const wordCount = post.body.split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

// JSON-LD BlogPosting schema (ported from the Jekyll _includes/head.html)
const siteOrigin = Astro.site?.origin ?? 'https://iptf.ethereum.org';
const articleUrl = new URL(post.url, siteOrigin).toString();
const imageAbs = post.image ? new URL(post.image, siteOrigin).toString() : undefined;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  ...(post.description ? { description: post.description } : {}),
  url: articleUrl,
  ...(post.date ? { datePublished: post.date } : {}),
  ...(imageAbs ? { image: imageAbs } : {}),
  ...(post.author ? { author: { '@type': 'Person', name: post.author } } : {}),
  publisher: {
    '@type': 'Organization',
    name: 'Institutional Privacy Task Force',
    url: 'https://iptf.ethereum.org',
  },
};
---

<Guide title={post.title} description={post.description} image={post.image} ogType="article">
  <article class="post">
    {post.image && (
      <div class="post-hero">
        <img src={post.image} alt="" loading="eager" />
      </div>
    )}

    <header class="post-header">
      <h1 class="post-title">{post.title}</h1>
      <div class="post-meta">
        <time datetime={post.date}>{formatPostDate(post.date)}</time>
        {post.author && <span class="post-author">{post.author}</span>}
        <span class="post-reading">{readingMinutes} min read</span>
      </div>
    </header>

    <div class="post-body prose">
      <slot />
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</Guide>

<style is:global>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 6rem 2rem 5rem;
  }
  .post-hero {
    margin-bottom: 2.5rem;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.05);
  }
  .post-hero img {
    width: 100%;
    height: auto;
    display: block;
  }
  .post-header {
    margin-bottom: 2.5rem;
  }
  .post-title {
    font-family: 'Newsreader', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 500;
    color: white;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 1rem;
  }
  .post-meta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 0.8rem;
    color: #71717a;
  }
  .post-meta time,
  .post-meta .post-author,
  .post-meta .post-reading {
    color: #71717a;
  }
  .post-meta .post-author::before,
  .post-meta .post-reading::before {
    content: '·';
    margin-right: 0.75rem;
    color: #3f3f46;
  }
  .post-body {
    font-size: 1rem;
    line-height: 1.75;
  }
  @media (max-width: 640px) {
    .post { padding: 5rem 1.25rem 4rem; }
    .post-title { font-size: 1.85rem; }
  }
</style>
