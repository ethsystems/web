---
/**
 * Renders the `visibility` frontmatter — per-actor view of what each
 * party can see at each layer. Present on 6/66 patterns; valuable
 * when present because it makes the privacy guarantee concrete.
 *
 * Upstream shape:
 *   visibility:
 *     counterparty: [amounts, identities, terms]
 *     chain: [message_type, commitment]
 *     regulator: [full_tx with view keys]
 *     public: []
 */

interface Props {
  counterparty?: string[];
  chain?: string[];
  regulator?: string[];
  public?: string[];
}

const { counterparty = [], chain = [], regulator = [], public: pub = [] } = Astro.props;
const anyContent = counterparty.length + chain.length + regulator.length + pub.length > 0;
if (!anyContent) return null;

const rows: Array<{ actor: string; items: string[] }> = [
  { actor: 'Counterparty', items: counterparty },
  { actor: 'Chain', items: chain },
  { actor: 'Regulator', items: regulator },
  { actor: 'Public', items: pub },
];
---

<section class="vis">
  <h3>Visibility</h3>
  <table>
    <thead>
      <tr>
        <th scope="col">Actor</th>
        <th scope="col">Sees</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <th scope="row">
            <span class="actor">{row.actor}</span>
          </th>
          <td>
            {row.items.length === 0 ? (
              <span class="empty" aria-label="empty">—</span>
            ) : (
              <ul>
                {row.items.map((it) => <li>{it}</li>)}
              </ul>
            )}
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</section>

<style>
  .vis {
    margin: 2rem 0;
  }
  .vis h3 {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.85rem;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg);
  }
  thead tr {
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
  }
  th, td {
    text-align: left;
    padding: 0.75rem 1rem;
    vertical-align: top;
  }
  thead th {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  tbody tr { border-bottom: 1px solid var(--color-border); }
  tbody tr:last-child { border-bottom: none; }
  tbody th {
    width: 11rem;
    font-weight: 600;
  }
  tbody th .actor {
    display: block;
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--color-primary);
  }
  td ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  td li {
    font-family: var(--font-mono);
    font-size: 11.5px;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    background: var(--color-bg-subtle);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }
  .empty {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text-muted);
  }
  @media (max-width: 600px) {
    tbody th { width: auto; }
    th, td { display: block; padding-bottom: 0.5rem; }
    tbody td { padding-top: 0; }
  }
</style>
