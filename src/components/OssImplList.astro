---
/**
 * Renders the `open_source_implementations` frontmatter array — a list
 * of reference implementations with URL, description, and language tag.
 *
 * Present on patterns and approaches alike (same schema shape upstream).
 */

interface Impl {
  url: string;
  description?: string;
  language?: string;
}

interface Props {
  heading?: string;
  items: Impl[];
}

const { heading = 'Open-source implementations', items } = Astro.props;
if (!items || items.length === 0) return null;

function hostname(url: string): string {
  try {
    return new URL(url).hostname.replace(/^www\./, '');
  } catch {
    return url;
  }
}
---

<section class="oss-list">
  <h3>{heading}</h3>
  <ul>
    {items.map((it) => (
      <li>
        <a href={it.url} target="_blank" rel="noopener">
          <div class="head">
            <span class="host">{hostname(it.url)}</span>
            {it.language && <span class="lang">{it.language}</span>}
          </div>
          {it.description && <p class="desc">{it.description}</p>}
          <span class="ext" aria-hidden="true">↗</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .oss-list {
    margin: 2rem 0;
  }
  .oss-list h3 {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.018em;
    color: var(--color-primary);
    margin-bottom: 0.85rem;
  }
  .oss-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .oss-list a {
    display: grid;
    grid-template-columns: 1fr auto;
    column-gap: 0.85rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--duration-fast) var(--easing-soft),
                box-shadow var(--duration-fast) var(--easing-soft);
  }
  .oss-list a:hover {
    border-color: var(--color-cta);
    box-shadow: var(--shadow-sm);
  }
  .head {
    grid-column: 1 / 2;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
  }
  .host {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.01em;
  }
  .lang {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    background: var(--color-bg-muted);
    color: var(--color-text-secondary);
  }
  .desc {
    grid-column: 1 / 2;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin-top: 0.25rem;
  }
  .ext {
    grid-column: 2 / 3;
    grid-row: 1 / 3;
    align-self: start;
    color: var(--color-text-muted);
    font-size: 14px;
    transition: color var(--duration-fast) var(--easing-soft);
  }
  .oss-list a:hover .ext { color: var(--color-cta); }
</style>
