<style>
  .supported {
    padding: 4rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  /* Tier row mirrors the coalition card: cells stretch to equal height,
     hairlines run between them. */
  .tier {
    display: flex;
    align-items: stretch;
  }
  .cell {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 24px;
  }
  .rule {
    width: 1px;
    align-self: center;
    height: 72px;
    flex: none;
    background: var(--color-border-strong);
  }
  .logo-slot {
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }
  .cap {
    margin-top: 16px;
