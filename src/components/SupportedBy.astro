  <div class="container">
    <div class="section-head">
      <h2>Supported by</h2>
      <p class="meta">The coalition standing behind EthSystems.</p>
    </div>
    <div class="tier">
      <div class="cell">
        <div class="logo-slot"><span class="wm-bitmine">BitMine</span></div>
        <div class="cap">Ethereum Treasury&thinsp;·&thinsp;BMNR</div>
      </div>
      <div class="rule" aria-hidden="true"></div>
      <div class="cell">
        <div class="logo-slot"><svg class="wm-sharplink"><use href="#sym-sharplink" /></svg></div>
        <div class="cap">Ethereum Treasury&thinsp;·&thinsp;SBET</div>
      </div>
      <div class="rule" aria-hidden="true"></div>
      <div class="cell">
        <div class="logo-slot"><span class="wm-lubin">Joe Lubin</span></div>
        <div class="cap">Co-Founder, Ethereum</div>
      </div>
      <div class="rule" aria-hidden="true"></div>
      <div class="cell">
        <div class="logo-slot"><svg class="wm-snz"><use href="#sym-snz-ink" /></svg></div>
        <div class="cap">Early Ethereum Backer</div>
      </div>
    </div>
  </div>
</section>

<style>
  .supported {
    padding: 4rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  /* Tier row mirrors the coalition card: cells stretch to equal height,
     hairlines run between them. */
  .tier {
    display: flex;
    align-items: stretch;
  }
  .cell {
    flex: 1 1 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 0 24px;
  }
  .rule {
    width: 1px;
    align-self: center;
    height: 72px;
    flex: none;
    background: var(--color-border-strong);
  }
  .logo-slot {
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
  }
  .cap {
    margin-top: 16px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-text-muted);
  }
  /* Partner wordmarks — scaled ~70% from the 1600px card. The card uses
     Inter for BitMine; the site ships Geist (--font-sans) so it stands
     in. SharpLink + SNZ are SVG marks in ink via currentColor. */
  .wm-bitmine {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 28px;
    letter-spacing: -0.015em;
    line-height: 1;
  }
  .wm-sharplink {
    width: 132px;
    height: 33px;
    display: block;
    color: inherit;
  }
  .wm-lubin {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 26px;
    letter-spacing: -0.005em;
    line-height: 1;
  }
  .wm-snz {
    width: 70px;
    height: 28px;
    display: block;
    color: inherit;
  }
  /* Collapse to 2×2 (drop hairlines) on tablet, single column on phone. */
  @media (max-width: 900px) {
    .tier {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 0;
    }
    .rule { display: none; }
  }
  @media (max-width: 560px) {
    .tier {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
