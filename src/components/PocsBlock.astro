---
/**
 * Renders the `iptf_pocs` block from an approach's frontmatter.
 *
 * Upstream shape:
 *   iptf_pocs:
 *     folder: pocs/<approach-folder>
 *     requirements: pocs/<approach-folder>/REQUIREMENTS.md
 *     pocs:
 *       - name: "..."
 *         sub_approach: "..."
 *         spec: pocs/<approach-folder>/<variant>/SPEC.md
 *         status: implemented | benchmarked | ...
 *
 * The folder + requirements + spec paths are relative to the `ethsystems/pocs`
 * repo, not the rendered site. We link them to the GitHub repo so users
 * can browse the spec without needing local clones.
 */

import { statusTone } from '../lib/statusTone';
import { site } from '../lib/site';

interface Poc {
  name: string;
  sub_approach?: string;
  spec?: string;
  status?: string;
}

interface Props {
  folder?: string;
  requirements?: string;
  pocs?: Poc[];
}

const { folder, requirements, pocs = [] } = Astro.props;
if (!folder && !requirements && pocs.length === 0) return null;

const REPO_BASE = `${site.pocsRepo}/tree/master`;
const BLOB_BASE = `${site.pocsRepo}/blob/master`;

function repoLink(path: string, kind: 'tree' | 'blob' = 'blob'): string {
  return `${kind === 'tree' ? REPO_BASE : BLOB_BASE}/${path}`;
}
---

<section class="pocs">
  <h3>Prototypes</h3>
  {(folder || requirements) && (
    <div class="links">
      {folder && (
        <a href={repoLink(folder, 'tree')} target="_blank" rel="noopener">
          <code>{folder}</code> <span aria-hidden="true">↗</span>
        </a>
      )}
      {requirements && (
        <a href={repoLink(requirements)} target="_blank" rel="noopener">
          REQUIREMENTS <span aria-hidden="true">↗</span>
        </a>
      )}
    </div>
  )}
  {pocs.length > 0 && (
    <ul>
      {pocs.map((p) => (
        <li>
          <div class="head">
            <h4>{p.name}</h4>
            {p.status && (
              <span class:list={['status', `tone-${statusTone(p.status)}`]}>{p.status}</span>
            )}
          </div>
          {p.sub_approach && <p class="sub">{p.sub_approach}</p>}
          {p.spec && (
            <a href={repoLink(p.spec)} target="_blank" rel="noopener" class="spec">
              View SPEC <span aria-hidden="true">↗</span>
            </a>
          )}
        </li>
      ))}
    </ul>
  )}
</section>

<style>
  .pocs {
    margin: 2rem 0;
    padding: 1.4rem 1.5rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }
  .pocs h3 {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.018em;
    color: var(--color-primary);
    margin-bottom: 0.85rem;
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .links a {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--color-cta);
    text-decoration: none;
    padding: 0.25rem 0.55rem;
    border-radius: var(--radius-sm);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: border-color var(--duration-fast) var(--easing-soft);
  }
  .links a:hover { border-color: var(--color-cta); }
  .links code {
    font-family: var(--font-mono);
    font-size: 12px;
  }
  .pocs ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .pocs li {
    padding: 0.85rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }
  .head {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-bottom: 0.25rem;
  }
  .head h4 {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.015em;
  }
  .status {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
  }
  .status.tone-strong { background: var(--color-success-tint); color: var(--color-success-strong); }
  .status.tone-mid { background: var(--color-warning-tint); color: var(--color-warning-strong); }
  .status.tone-plain { background: var(--color-bg-muted); color: var(--color-text-secondary); }
  .sub {
    font-size: 13px;
    color: var(--color-text-secondary);
    line-height: 1.5;
    margin-bottom: 0.4rem;
  }
  .spec {
    font-family: var(--font-mono);
    font-size: 11.5px;
    font-weight: 600;
    color: var(--color-cta);
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .spec:hover { text-decoration: underline; }
</style>
