---
/**
 * Renders the `sub_patterns` frontmatter array — variants the pattern
 * subsumes, each with its own CROPS-summary line and link to the
 * variant's own pattern page. Present on 3/66 patterns
 * (modular-privacy-stack, network-anonymity, pretrade-privacy-encryption).
 *
 * Slug resolution happens in the caller via `resolveSlugs('patterns', …)` —
 * this component is purely presentational.
 */

import { inlineMd } from '../lib/inlineMarkdown';

interface Variant {
  name: string;
  href: string;
  crops_summary?: string;
}

interface Props {
  variants: Variant[];
}

const { variants } = Astro.props;
if (!variants || variants.length === 0) return null;
---

<section class="sub-patterns">
  <h3>Variants</h3>
  <ol>
    {variants.map((v, i) => (
      <li>
        <a href={v.href}>
          <span class="num">{(i + 1).toString().padStart(2, '0')}</span>
          <div class="body">
            <h4>{v.name}</h4>
            {v.crops_summary && <p set:html={inlineMd(v.crops_summary)} />}
          </div>
          <span class="arr">→</span>
        </a>
      </li>
    ))}
  </ol>
</section>

<style>
  .sub-patterns {
    margin: 2rem 0;
  }
  .sub-patterns h3 {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.85rem;
  }
  .sub-patterns ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    counter-reset: var-counter;
  }
  .sub-patterns a {
    display: grid;
    grid-template-columns: 2.5rem 1fr 1rem;
    gap: 0.85rem;
    align-items: start;
    padding: 0.85rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--duration-fast) var(--easing-soft),
                box-shadow var(--duration-fast) var(--easing-soft);
  }
  .sub-patterns a:hover {
    border-color: var(--color-cta);
    box-shadow: var(--shadow-sm);
  }
  .num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.06em;
    padding-top: 0.25rem;
  }
  .body h4 {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.015em;
    margin-bottom: 0.25rem;
  }
  .body p {
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-text-secondary);
    margin: 0;
  }
  .body p :global(code) {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 0.05rem 0.35rem;
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }
  .arr {
    color: var(--color-text-muted);
    font-weight: 600;
    align-self: center;
    transition: transform var(--duration-fast) var(--easing-soft),
                color var(--duration-fast) var(--easing-soft);
  }
  .sub-patterns a:hover .arr {
    color: var(--color-cta);
    transform: translateX(3px);
  }
</style>
