---
/**
 * Renders the `standards` frontmatter array as a chip row.
 * 40/66 patterns carry a non-empty standards list (e.g. ERC-20,
 * EIP-5564, ISO-20022). 23 ship an explicit empty list — we hide
 * the component in that case.
 */

interface Props {
  items?: string[];
}

const items = (Astro.props.items ?? []).filter(Boolean);
if (items.length === 0) return null;
---

<section class="standards">
  <h3>Standards</h3>
  <ul>
    {items.map((s) => <li>{s}</li>)}
  </ul>
</section>

<style>
  .standards {
    margin: 1.5rem 0;
  }
  .standards h3 {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: 0.6rem;
  }
  .standards ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .standards li {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }
</style>
