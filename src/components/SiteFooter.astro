---
import { site } from '../lib/site';
import markBlack from '../assets/logos/mark-black.svg?raw';
---

<footer class="site">
  <div class="container">
    <div class="foot-grid">
      <div class="foot-brand">
        <a class="brand" href="/" aria-label="EthSystems">
          <span class="brand-mark" aria-hidden="true" set:html={markBlack}></span>
          <span class="brand-name">EthSystems</span>
        </a>
        <p>Institutional privacy on Ethereum. A working knowledge base for institutions moving on-chain with privacy requirements.</p>
      </div>
      <div>
        <h5>The Guide</h5>
        <ul>
          <li><a href="/use-cases/">Use cases</a></li>
          <li><a href="/approaches/">Approaches</a></li>
          <li><a href="/patterns/">Building blocks</a></li>
          <li><a href="/vendors/">Vendor profiles</a></li>
          <li><a href="/jurisdictions/">Jurisdictions</a></li>
          <li><a href="/domains/">Domains</a></li>
          <li><a href="/blog/">Blog</a></li>
        </ul>
      </div>
      <div>
        <h5>Standing matter</h5>
        <ul>
          <li><a href="/about/">About</a></li>
          {/* <li><a href="/join/">Join us</a></li> */}
          <li><a href="/faq/">FAQ</a></li>
          <li><a href={`${site.mapRepo}/blob/master/CONTRIBUTING.md`}>Contributing</a></li>
          <li><a href="/glossary/">Glossary</a></li>
          <li><a href={`${site.mapRepo}/blob/master/CHANGELOG.md`}>Changelog</a></li>
        </ul>
      </div>
      <div>
        <h5>Source</h5>
        <ul>
          <li><a href={site.mapRepo}>github · map</a></li>
          <li><a href={site.pocsRepo}>github · pocs</a></li>
        </ul>
      </div>
    </div>
    <div class="foot-bottom">
      <span class="foot-copy">© 2026 EthSystems</span>
      <ul class="foot-social" role="list">
        <li><a href={site.github} target="_blank" rel="noopener noreferrer">GitHub</a></li>
        <li><a href={site.x} target="_blank" rel="noopener noreferrer">X</a></li>
        <li><a href={site.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  footer.site {
    background: var(--sunken);
    border-top: 1px solid var(--line);
    color: var(--ink-2);
    font-size: 14px;
    padding: 4rem 0 2.25rem;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: 2.25rem;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 800px) {
    .foot-grid { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .foot-grid .foot-brand { grid-column: 1 / -1; }
  }
  .foot-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--ink);
    text-decoration: none;
  }
  .foot-brand .brand-mark { display: inline-flex; }
  .foot-brand .brand-mark :global(svg) { display: block; height: 34px; width: auto; }
  .foot-brand .brand-name {
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 15px;
    color: var(--ink);
  }
  .foot-brand p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    margin-top: 1rem;
    max-width: 34ch;
  }
  .foot-grid h5 {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }
  .foot-grid ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .foot-grid a {
    color: var(--ink-2);
    font-size: 14px;
    text-decoration: none;
    transition: color var(--duration-fast) var(--easing-soft);
  }
  .foot-grid a:hover { color: var(--navy); }
  .foot-bottom {
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 12px;
    color: var(--muted);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
  .foot-social {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
  }
  .foot-social a {
    color: var(--muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--easing-soft);
  }
  .foot-social a:hover { color: var(--navy); }
</style>
