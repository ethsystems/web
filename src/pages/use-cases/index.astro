---
import { getCollection } from 'astro:content';
import ListPageLayout from '../../layouts/ListPageLayout.astro';
import AnchorNav from '../../components/AnchorNav.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import UseCaseCard from '../../components/UseCaseCard.astro';
import { buildDomainIndex, type Domain } from '../../lib/domain';
import { domainIcon } from '../../lib/icons';
import { bodyExcerpt, bodyBulletList } from '../../lib/excerpt';
import { inlineMd } from '../../lib/inlineMarkdown';

/*
 * Use-case status convention (upstream):
 *   - `status: stub`  → no case study written yet
 *   - absent / other  → case study exists for this use case
 * The "case study available" chip on each card derives from this rule.
 * Previously this was a hardcoded USE_CASE_STATUS map in copy.ts that
 * drifted from frontmatter — now read straight from entry.data.
 */
function hasCaseStudy(status?: string): boolean {
  return !status || status.toLowerCase() !== 'stub';
}

const useCases = await getCollection('useCases');

// Domains are data-driven from the `domains` collection — adding or
// removing a domain upstream is reflected here with no code change.
const domains = await getCollection('domains');
const domainIndex = buildDomainIndex(domains);

const grouped = new Map<Domain, typeof useCases>();
for (const name of domainIndex.names) grouped.set(name, [] as unknown as typeof useCases);
for (const uc of useCases) {
  const name = domainIndex.resolve(uc.data.primary_domain);
  if (name) grouped.get(name)!.push(uc);
}
const orderedDomains: Domain[] = domainIndex.names.filter((d) => grouped.get(d)!.length > 0);

// Per-domain primer is the domain's frontmatter `description` (a curated
// one-liner, iptf-map PR #173). Falls back to the first ## TLDR bullet
// where no description exists yet. Links to the domain detail page.
function domainPrimer(d: Domain): { html: string; href: string } | undefined {
  const entry = domainIndex.entryFor(d) as
    | { id: string; data: { description?: string }; body?: string }
    | undefined;
  if (!entry) return undefined;
  const text = entry.data.description?.trim() || bodyBulletList(entry.body, 'TLDR')[0];
  if (!text) return undefined;
  return { html: `<p>${inlineMd(text)}</p>`, href: `/domains/${entry.id}/` };
}

function anchor(domain: string): string {
  return domain.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

const tabs = orderedDomains.map((d) => ({
  href: `#${anchor(d)}`,
  label: d,
  count: grouped.get(d)!.length,
  iconSvg: domainIcon(domainIndex.idFor(d)),
}));

---

<ListPageLayout
  title="Use cases"
  pageTitle="Use cases"
  description="Use cases"
  current="/use-cases/"
>
  <Fragment slot="anchor-nav">
    <AnchorNav tabs={tabs} ariaLabel="Domain navigation" />
  </Fragment>

  <div class="container">
    {orderedDomains.map((domain) => {
      const primer = domainPrimer(domain);
      return (
      <section class="domain-section">
        <SectionHeading
          id={anchor(domain)}
          title={domain}
          iconSvg={domainIcon(domainIndex.idFor(domain))}
          primer={primer?.html}
          readMoreHref={primer?.href}
        />
        <div class="uc-grid">
          {grouped.get(domain)!.map((uc) => (
            <UseCaseCard
              href={`/use-cases/${uc.id}/`}
              title={uc.data.title}
              gloss={bodyExcerpt(uc.body, '1) Use Case')}
              status={hasCaseStudy(uc.data.status) ? 'published' : 'stub'}
            />
          ))}
        </div>
      </section>
      );
    })}

  </div>
</ListPageLayout>

<style>
  .domain-section {
    margin-bottom: 4rem;
  }
  .domain-section:last-of-type { margin-bottom: 1rem; }
  .uc-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  @media (max-width: 800px) {
    .uc-grid { grid-template-columns: 1fr; }
  }
</style>
