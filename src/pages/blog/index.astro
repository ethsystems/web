---
/*
 * /blog/ — long-form writeups index.
 *
 * Source: the `posts` content collection, tracked directly in src/posts/.
 * Single unified list of all posts, sorted newest-first. Matches the
 * upstream /blog at ethsystems/web — no curated "featured" section, no
 * split with weekly updates.
 */
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import ListPageLayout from '../../layouts/ListPageLayout.astro';
import NextStepCTA from '../../components/NextStepCTA.astro';
import { jekyllSlugify } from '../../lib/jekyllSlug';
import { isPublished } from '../../lib/posts';
import { site } from '../../lib/site';

function toISODate(d: string | Date | undefined): string {
  if (!d) return '';
  if (d instanceof Date) return d.toISOString().slice(0, 10);
  return String(d).slice(0, 10);
}

const all = await getCollection('posts');
const posts = all
  .filter((p) => isPublished(p))
  .map((p) => ({
    slug: jekyllSlugify(p.data.title),
    title: p.data.title,
    description: p.data.description ?? '',
    date: toISODate(p.data.date),
    author: p.data.author,
    image: p.data.image,
  }))
  .sort((a, b) => b.date.localeCompare(a.date));

const today = new Date().toISOString().slice(0, 10);
---

<ListPageLayout
  title="Blog"
  pageTitle="Writeups"
  description="Field notes from Ethereum Systems on building privacy on Ethereum for institutional use cases."
  current="/blog/"
  lede={`Field notes from Ethereum Systems on building privacy on Ethereum for institutional use cases.`}
  metaRow={`${posts.length} writeups · Updated <strong>${today}</strong>`}
>
  <div class="container">
    <ul class="post-list">
      {posts.map((p) => (
        <li>
          <a href={`/blog/${p.slug}/`} class="post-row">
            {p.image && (
              <div class="post-thumb">
                <Image src={p.image} alt="" width={480} format="webp" loading="lazy" />
              </div>
            )}
            <div class="post-body">
              <div class="post-meta">
                {p.date && <time>{p.date}</time>}
                {p.author && <span>· {p.author}</span>}
              </div>
              <h3>{p.title}</h3>
              {p.description && <p>{p.description}</p>}
            </div>
          </a>
        </li>
      ))}
    </ul>

    <NextStepCTA
      heading="Want the next post in your inbox?"
      body="Ethereum Systems posts long-form research as the map evolves. Watch the map repo on GitHub or contact the team directly."
      ctaLabel="Watch on GitHub"
      ctaHref={site.mapRepo}
    />
  </div>
</ListPageLayout>

<style>
  .post-list {
    list-style: none;
    padding: 0;
    /* No top margin — the shared .list-body already supplies the 2rem
       top padding. A margin here doubled it, leaving a ~96px gap under
       the header. */
    margin: 0 0 4rem;
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .post-list li {
    background: var(--color-bg);
  }
  .post-row {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 1.25rem;
    padding: 1.1rem 1.25rem;
    text-decoration: none;
    transition: background var(--duration-fast) var(--easing-soft);
  }
  .post-row:hover {
    background: var(--color-bg-subtle);
  }
  .post-thumb {
    width: 120px;
    height: 80px;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--color-bg-muted);
    flex-shrink: 0;
  }
  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .post-body {
    min-width: 0;
  }
  .post-meta {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    margin-bottom: 0.35rem;
  }
  .post-row h3 {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 0.35rem;
    letter-spacing: -0.015em;
    line-height: 1.3;
    transition: color var(--duration-fast) var(--easing-soft);
  }
  .post-row:hover h3 {
    color: var(--color-cta);
  }
  .post-row p {
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .post-row {
      grid-template-columns: 1fr;
    }
    .post-thumb {
      width: 100%;
      height: 140px;
    }
  }
</style>
