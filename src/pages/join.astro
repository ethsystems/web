---
/*
 * Join page — hidden careers page. Reachable only by direct URL: it's
 * noindex,nofollow (BaseLayout `noindex`), excluded from the sitemap
 * (astro.config.mjs filter), and not linked from nav or footer (those
 * links exist but are commented out). Mirrors about.astro's structure
 * (BaseLayout + PageHeader) and reuses the .contact-card pattern from
 * that page, copied locally into this file's scoped styles.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { site } from '../lib/site';

const pageDescription =
  "We're a team building confidential systems for institutional Ethereum.";
---

<BaseLayout
  title="Join us"
  description={pageDescription}
  current="/join/"
  image="/og/join.png"
  noindex
>
  <PageHeader
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Join us' },
    ]}
    title="Join us"
    lede="We're a team building confidential systems for institutional Ethereum."
  />

  <section class="join-section">
    <div class="container join-inner">
      <div class="join-roles">
        <h2>Open roles</h2>
        <p class="join-roles-lede">Roles will be listed here as they open. If you think you'd be a fit, reach out.</p>
        <div class="contact-row">
          <a href={`mailto:${site.careersEmail}`} class="contact-card">
            <div class="contact-label">Careers</div>
            <div class="contact-value">{site.careersEmail}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M9 7h8v8" /></svg></div>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .join-section {
    padding: 2rem 0 5rem;
  }
  .join-roles h2 {
    font-family: var(--font-sans);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }
  .join-roles-lede {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.65;
    margin: 0 0 1.5rem;
    max-width: 640px;
  }
  /* .contact-row + .contact-card copied from about.astro so the careers
     CTA reads identically to the About page's contact card. */
  .contact-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--easing-soft),
      background var(--duration-fast) var(--easing-soft);
    min-width: 240px;
  }
  .contact-card:hover {
    border-color: var(--color-cta-border);
    background: var(--color-cta-tint);
  }
  .contact-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }
  .contact-value {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-cta);
  }
  .contact-value svg { width: 12px; height: 12px; }
</style>
