---
import Guide from '../../layouts/Guide.astro';
import { getNodesByType } from '../../lib/data';

const vendors = getNodesByType('vendor').sort((a, b) => a.title.localeCompare(b.title));
const base = import.meta.env.BASE_URL;
---

<Guide title="Vendors" description="Neutral assessments of privacy infrastructure providers" activeSection="vendors">
  <div style="max-width:1200px; margin:0 auto; padding:6rem 2rem 4rem;">

    <div style="margin-bottom:3rem;">
      <div style="font-size:0.65rem; font-weight:700; color:#818cf8; letter-spacing:0.12em; text-transform:uppercase; margin-bottom:0.5rem;">Vendors</div>
      <h1 style="font-family:'Newsreader',Georgia,serif; font-size:2.5rem; font-weight:400; color:white; letter-spacing:-0.025em; line-height:1.15; margin-bottom:0.75rem;">Privacy infrastructure providers</h1>
      <p style="font-size:1rem; color:#a1a1aa; line-height:1.7; max-width:640px;">{vendors.length} vendor assessments. Neutral and factual — no ranking, no endorsement. Each entry describes what the vendor builds, what it fits with, and what trade-offs to consider.</p>
    </div>

    <!-- Neutral disclaimer -->
    <div style="display:flex; align-items:center; gap:10px; padding:0.75rem 1rem; border-radius:8px; background:rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.05); margin-bottom:3rem; font-size:0.75rem; color:#71717a;">
      <svg style="width:16px; height:16px; flex-shrink:0; color:#52525b;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      IPTF vendor assessments are neutral and factual. Evaluate based on your own requirements.
    </div>

    <!-- Editorial list -->
    <div>
      {vendors.map((v, i) => {
        const isLast = i === vendors.length - 1;
        return (
          <a href={`/vendors/${v.slug}`} style={`display:grid; grid-template-columns:1fr auto; gap:2rem; align-items:center; padding:1.35rem 0; border-top:1px solid rgba(255,255,255,0.06); ${isLast ? 'border-bottom:1px solid rgba(255,255,255,0.06);' : ''} text-decoration:none; color:inherit; transition:all 0.15s;`} onmouseover="this.style.paddingLeft='0.75rem'; this.querySelector('.name').style.color='#a5b4fc';" onmouseout="this.style.paddingLeft='0'; this.querySelector('.name').style.color='white';">
            <div>
              <div class="name" style="font-family:'Newsreader',Georgia,serif; font-size:1.2rem; font-weight:500; color:white; letter-spacing:-0.01em; margin-bottom:0.25rem; transition:color 0.15s;">{v.title}</div>
              <div style="font-size:0.82rem; color:#71717a; line-height:1.5;">{v.summary}</div>
            </div>
            <div style="display:flex; gap:6px; align-items:center; flex-shrink:0;">
              {v.maturity && <span style="font-size:0.65rem; font-weight:600; padding:3px 8px; border-radius:4px; background:rgba(52,211,153,0.1); color:#34d399;">{v.maturity}</span>}
              {v.category && <span style="font-size:0.65rem; font-weight:600; padding:3px 8px; border-radius:4px; background:rgba(255,255,255,0.06); color:#a1a1aa;">{v.category}</span>}
            </div>
          </a>
        );
      })}
    </div>

  </div>
</Guide>
