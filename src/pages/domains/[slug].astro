---
/*
 * Domain detail — refactored per the ethsystems/web merge handoff
 * (locked 2026-05-19, "theirs structure exactly + our card visuals").
 *
 * Adds three new structural pieces above the existing body prose:
 *   1) Inter-domain pill row (active = cta-blue filled, others gray-bordered).
 *   2) "Building blocks for {domain}" — PatternCard grid filtered by domain.
 *   3) "Who builds {domain} tooling" — vendor card grid filtered by domain.
 *
 * Domain membership comes from graph.json's in-domain edges (generated
 * by scripts/build-graph.mjs from upstream body links). Patterns are
 * rendered with our PatternCard; vendors with a card structure matched
 * to PatternCard's idiom (no dedicated VendorCard yet — kept simple).
 */
import { getCollection } from 'astro:content';
import DetailPageLayout from '../../layouts/DetailPageLayout.astro';
import PatternCard from '../../components/PatternCard.astro';
import { stripTypePrefix } from '../../lib/slugify';
import { bodyBulletList, popSection } from '../../lib/excerpt';
import { renderMarkdown } from '../../lib/render';
import graphData from '../../data/graph.json';

interface GraphEdge {
  source: string;
  target: string;
  type: string;
}

export async function getStaticPaths() {
  const entries = await getCollection('domains');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const title = stripTypePrefix(entry.data.title);

// Lift the `## TLDR` bullets into the hero (rendered as a list under
// the title). The body always renders without TLDR so the same content
// doesn't appear twice and the literal "TLDR" heading never shows.
const tldrBullets = bodyBulletList(entry.body, 'TLDR');
// Strip body sections that the card grids below re-render with
// richer metadata, to avoid showing the same list twice:
//   - "Shortest-path patterns" → "Building blocks for {domain}" grid
//   - "Adjacent vendors"       → "Who builds {domain} tooling" grid
// Sections are popped sequentially because popSection only knows about
// one heading at a time. Each call returns the body with that section
// excised; we thread the result through.
let stripped = entry.body;
for (const heading of ['TLDR', 'Shortest-path patterns', 'Adjacent vendors']) {
  stripped = popSection(stripped, heading).bodyWithout;
}
const bodyHtml = renderMarkdown(stripped);

const allDomains = await getCollection('domains');

// Graph-driven domain membership. The build-graph "in-domain" edges
// flow from body markdown — direction can go either way, so we accept
// both ends.
const edges = graphData.edges as GraphEdge[];
const domainNodeId = `domain/${entry.id}`;
const inDomainIds = new Set<string>();
for (const e of edges) {
  if (e.type !== 'in-domain') continue;
  if (e.source === domainNodeId) inDomainIds.add(e.target);
  if (e.target === domainNodeId) inDomainIds.add(e.source);
}

const allPatterns = await getCollection('patterns');
const allVendors = await getCollection('vendors');

const domainPatterns = allPatterns
  .filter((p) => inDomainIds.has(`pattern/${p.id.replace(/^pattern-/, '')}`))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const domainVendors = allVendors
  .filter((v) => inDomainIds.has(`vendor/${v.id}`))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const lowerTitle = title.toLowerCase();
---

<DetailPageLayout
  title={`${title} · Domain`}
  pageTitle={title}
  description={tldrBullets.join(' ')}
  current="/domains/"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Domains', href: '/domains/' },
    { label: title },
  ]}
  ledeBullets={tldrBullets}
>
  <div class="prose domain-prose" set:html={bodyHtml} />

  {domainPatterns.length > 0 && (
    <section class="domain-block">
      <h2>Building blocks for {lowerTitle}</h2>
      <div class="card-grid">
        {domainPatterns.map((p) => (
          <PatternCard
            href={`/patterns/${p.id}/`}
            title={p.data.title}
            privacyGoal={p.data.privacy_goal}
            layer={p.data.layer}
            maturity={p.data.maturity}
            cropsProfile={
              p.data.crops_profile && typeof p.data.crops_profile === 'object'
                ? (p.data.crops_profile as Record<string, string>)
                : null
            }
          />
        ))}
      </div>
    </section>
  )}

  {domainVendors.length > 0 && (
    <section class="domain-block">
      <h2>Who builds {lowerTitle} tooling</h2>
      <div class="vendor-grid">
        {domainVendors.map((v) => (
          <a class="vendor-card" href={`/vendors/${v.id}/`}>
            <h3>{stripTypePrefix(v.data.title)}</h3>
            {v.data.maturity && (
              <span class="vendor-maturity">{v.data.maturity}</span>
            )}
          </a>
        ))}
      </div>
    </section>
  )}

</DetailPageLayout>

<style>
  /* The body's first `## ` heading is the first content under the
     page header on domain pages, so its top divider would read as
     a stray hairline directly under the title. The `.domain-prose`
     class scopes this strip to domains only — pattern / approach
     pages still keep the first-h2 divider where it's intentional. */
  :global(.domain-prose > h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .domain-block {
    margin: 3rem 0 0;
  }
  .domain-block h2 {
    font-family: var(--font-sans);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
    line-height: 1.25;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .vendor-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }
  .vendor-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 1rem 1.1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color var(--duration-fast) var(--easing-soft),
      box-shadow var(--duration-fast) var(--easing-soft);
  }
  .vendor-card:hover {
    border-color: var(--color-cta-border);
    box-shadow: var(--shadow-md);
  }
  .vendor-card h3 {
    font-family: var(--font-sans);
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .vendor-maturity {
    font-family: var(--font-mono);
    font-size: 10.5px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
</style>
