---
/*
 * Glossary page — ported from ethereum/iptf-web (`src/pages/glossary.astro`,
 * test_guide branch). Terms come from glossary.json, generated by
 * scripts/build-graph.mjs from iptf-map's GLOSSARY.md.
 *
 * Lemma rename per handoff (B2B/B2C — chrome only, locked 2026-05-19):
 *   "I2I (Institution-to-Institution)" → "B2B (Business-to-Business / Institution-to-Institution)"
 *   "I2U (Institution-to-End-User)"    → "B2C (Business-to-Consumer  / Institution-to-End-User)"
 * Definitions in the body stay verbatim — only the term lemma changes.
 *
 * Re-skinned to our light theme + tokens. Search + scroll-spy nav match
 * theirs' interactive behavior.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import glossaryData from '../data/glossary.json';

interface Term {
  term: string;
  definition: string;
  category: string;
}

// Lemma rename — chrome-only, preserves the institutional name as the second clause.
function renameTerm(term: string): string {
  if (term.startsWith('I2I (')) {
    return term.replace(/^I2I \(Institution-to-Institution\)/, 'B2B (Business-to-Business / Institution-to-Institution)');
  }
  if (term.startsWith('I2U (')) {
    return term.replace(/^I2U \(Institution-to-End-User\)/, 'B2C (Business-to-Consumer / Institution-to-End-User)');
  }
  return term;
}

const allTerms: Term[] = (glossaryData as Term[])
  .filter((t) => t.definition && t.term)
  .map((t) => ({ ...t, term: renameTerm(t.term) }));

// Preserve first-appearance order so the nav order reads in the same
// rhythm as the source GLOSSARY.md.
const categoryOrder: string[] = [];
const grouped: Record<string, Term[]> = {};
for (const entry of allTerms) {
  if (!grouped[entry.category]) {
    grouped[entry.category] = [];
    categoryOrder.push(entry.category);
  }
  grouped[entry.category].push(entry);
}

function catSlug(name: string): string {
  return name
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
}

const pageDescription = `${allTerms.length} terms used across the IPTF guide. Organized by category — the same definitions surface as inline tooltips throughout the site.`;
---

<BaseLayout
  title="Glossary"
  description={pageDescription}
  current="/glossary/"
>
  <PageHeader
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Glossary' },
    ]}
    title="Terms and definitions"
    lede={pageDescription}
  />

  <section class="glossary">
    <div class="glossary-inner">
      <div class="glossary-search-row">
        <div class="glossary-search">
          <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8" />
            <path d="M21 21l-4.35-4.35" />
          </svg>
          <input
            type="search"
            id="glossary-search"
            placeholder="Search terms or definitions…"
            autocomplete="off"
          />
        </div>
      </div>

      <div class="glossary-grid" id="glossary-grid">
        <nav class="cat-nav" id="cat-nav" aria-label="Glossary categories">
          {categoryOrder.map((cat, i) => (
            <a
              href={`#${catSlug(cat)}`}
              class:list={['cat-nav-link', { active: i === 0 }]}
              data-cat={catSlug(cat)}
            >
              {cat}
            </a>
          ))}
        </nav>

        <div class="terms" id="glossary-terms">
          {categoryOrder.map((cat) => (
            <div class="cat-section" id={catSlug(cat)} data-category={catSlug(cat)}>
              <div class="cat-label">{cat}</div>
              {grouped[cat].map((entry) => (
                <div
                  class="g-term"
                  data-term={entry.term.toLowerCase()}
                  data-def={entry.definition.toLowerCase()}
                >
                  <div class="g-term-name">{entry.term}</div>
                  <div class="g-term-def">{entry.definition}</div>
                </div>
              ))}
            </div>
          ))}
          <div class="g-empty" id="g-empty" hidden>No terms match that search.</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('glossary-search') as HTMLInputElement | null;
  const terms = Array.from(document.querySelectorAll<HTMLElement>('.g-term'));
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.cat-section'));
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.cat-nav-link'));
  const empty = document.getElementById('g-empty');

  if (input) {
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase().trim();
      let totalVisible = 0;
      terms.forEach((t) => {
        const name = t.dataset.term ?? '';
        const def = t.dataset.def ?? '';
        const match = !q || name.includes(q) || def.includes(q);
        t.style.display = match ? '' : 'none';
        if (match) totalVisible++;
      });
      sections.forEach((sec) => {
        const anyVisible = Array.from(sec.querySelectorAll<HTMLElement>('.g-term')).some(
          (t) => t.style.display !== 'none',
        );
        sec.style.display = anyVisible ? '' : 'none';
      });
      if (empty) empty.hidden = totalVisible > 0;
    });
  }

  // Scroll-spy: highlight nav link when category section enters viewport.
  if (sections.length > 0 && navLinks.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach((link) => {
              link.classList.toggle('active', link.dataset.cat === id);
            });
          }
        });
      },
      { rootMargin: '-80px 0px -60% 0px', threshold: 0 },
    );
    sections.forEach((sec) => observer.observe(sec));
  }
</script>

<style>
  .glossary {
    padding: 2rem 0 4rem;
  }
  .glossary-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--container-pad);
  }

  .glossary-search-row {
    margin-bottom: 2rem;
  }
  .glossary-search {
    position: relative;
    max-width: 480px;
  }
  .glossary-search .search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    width: 16px;
    height: 16px;
    color: var(--color-text-muted);
    pointer-events: none;
  }
  #glossary-search {
    width: 100%;
    padding: 0.75rem 1rem 0.75rem 2.6rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    outline: none;
    transition: border-color var(--duration-fast) var(--easing-soft),
      box-shadow var(--duration-fast) var(--easing-soft);
  }
  #glossary-search::placeholder {
    color: var(--color-text-muted);
  }
  #glossary-search:focus {
    border-color: var(--color-cta);
    box-shadow: 0 0 0 3px var(--color-cta-tint);
  }

  .glossary-grid {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 3rem;
    align-items: start;
  }

  .cat-nav {
    position: sticky;
    top: 80px;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cat-nav-link {
    display: block;
    padding: 0.45rem 0.6rem;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    border-radius: var(--radius-sm);
    border-left: 2px solid transparent;
    transition: color var(--duration-fast) var(--easing-soft),
      border-color var(--duration-fast) var(--easing-soft),
      background var(--duration-fast) var(--easing-soft);
  }
  .cat-nav-link:hover {
    color: var(--color-primary);
    background: var(--color-bg-subtle);
  }
  .cat-nav-link.active {
    color: var(--color-cta);
    border-left-color: var(--color-cta);
    background: var(--color-cta-tint);
  }

  .cat-section {
    margin-bottom: 2.5rem;
    scroll-margin-top: 80px;
  }
  .cat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .g-term {
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .g-term:last-child {
    border-bottom: none;
  }
  .g-term-name {
    font-family: var(--font-sans);
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.3rem;
    letter-spacing: -0.01em;
  }
  .g-term-def {
    font-size: 0.92rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .g-empty {
    padding: 2rem 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .glossary-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    .cat-nav {
      position: static;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 4px;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }
    .cat-nav-link {
      font-size: 0.75rem;
      padding: 0.35rem 0.6rem;
      border-left: none;
      border-bottom: 2px solid transparent;
    }
    .cat-nav-link.active {
      border-left: none;
      border-bottom-color: var(--color-cta);
    }
  }
</style>
