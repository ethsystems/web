---
/*
 * Approach detail — section-routed render ported from ethereum/iptf-web.
 *
 * Per the iptf-web merge handoff (notes/iptf-web-merge-handoff.md): the
 * upstream approach markdown has a fixed H2 structure (Problem framing,
 * Approaches, Comparison, Persona perspectives, Recommendation, Open
 * questions, Example scenario). Instead of flat-rendering the body, we
 * parse each named section out and lay them into bespoke UI: persona
 * tabs, architectural-options grid, comparison table, recommendation
 * call-out, etc. Styling stays in our light theme + tokens.
 *
 * Sub-approach blocks inside `## Approaches` are parsed from labelled
 * `**Summary:**` paragraphs and a fenced ```yaml block (maturity,
 * context, crops, uses_patterns, poc_spec, example_vendors).
 */
import { getCollection } from 'astro:content';
import yaml from 'js-yaml';
import DetailPageLayout from '../../layouts/DetailPageLayout.astro';
import CropsPie from '../../components/CropsPie.astro';
import { parseApproachTitle } from '../../lib/parseApproachTitle';
import { stripTypePrefix } from '../../lib/slugify';
import { bodyExcerpt } from '../../lib/excerpt';
import { getReferencedBy } from '../../lib/related';
import {
  parseSections,
  getSection,
  parseSubSections,
  extractLabelledBlock,
  extractYamlBlock,
} from '../../lib/parse-sections';
import { renderMarkdown } from '../../lib/render';

export async function getStaticPaths() {
  const entries = await getCollection('approaches');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

// Title precedence: frontmatter > body H1 > slug. parseApproachTitle
// remains the fallback because upstream's privacy-standards-survey
// approach currently ships without frontmatter.
const title = entry.data.title
  ? stripTypePrefix(entry.data.title)
  : parseApproachTitle(entry.body) || entry.id;
// `lede` is assigned below, after we've parsed `pfScenario`, so we can
// lift the scenario paragraph into the hero and avoid duplicating it
// further down the page. Falls back to bodyExcerpt for approaches that
// don't define a `### Scenario` subsection.

// Use-case + domain resolution for header context badge.
const useCases = await getCollection('useCases');
const useCaseEntry = entry.data.use_case
  ? useCases.find((uc) => uc.id === entry.data.use_case)
  : null;
const useCaseTitle = useCaseEntry ? stripTypePrefix(useCaseEntry.data.title) : null;

// Title pills removed per IA call — status / domain / use-case were
// surfaced elsewhere (sidebar's Related use cases, breadcrumb context)
// and crowded the hero. The variables are kept inline above for
// breadcrumb labelling and the use-case eyebrow inside the persona
// header if needed in future.

const lastReviewed = entry.data.last_reviewed
  ? typeof entry.data.last_reviewed === 'string'
    ? entry.data.last_reviewed
    : new Date(entry.data.last_reviewed).toISOString().slice(0, 10)
  : undefined;

// Section routing — parse body into named H2 sections.
const sections = parseSections(entry.body);
const problemFraming = getSection(sections, 'problem-framing') || getSection(sections, 'problem');
const approachesSec = getSection(sections, 'approaches');
const comparison = getSection(sections, 'comparison');
const personas = getSection(sections, 'persona-perspectives') || getSection(sections, 'persona');
const recommendation = getSection(sections, 'recommendation');
const openQuestions = getSection(sections, 'open-questions') || getSection(sections, 'open');
const exampleScenario =
  getSection(sections, 'example-scenario') || getSection(sections, 'example');

// Problem framing → Scenario / Requirements / Constraints
const pfSubs = problemFraming ? parseSubSections(problemFraming.content) : [];
const pfScenario = pfSubs.find((s) => s.key === 'scenario');
const pfRequirements = pfSubs.find((s) => s.key === 'requirements');
const pfConstraints = pfSubs.find((s) => s.key === 'constraints');

// Lift the scenario paragraph into the hero in FULL so it doesn't
// appear twice (once in the hero, once as a body section). The
// generic bodyExcerpt truncates at ~220 chars which was clipping the
// scenario; here we want the whole first paragraph verbatim.
// Falls back to a generic body excerpt if no scenario section.
function scenarioParagraph(md: string): string {
  const para: string[] = [];
  for (const raw of md.split('\n')) {
    const line = raw.trim();
    if (!line) { if (para.length > 0) break; continue; }
    if (line.startsWith('#') || line.startsWith('-') || line.startsWith('*') ||
        line.startsWith('>') || /^\d+[).]/.test(line) || line.startsWith('```')) {
      if (para.length > 0) break; continue;
    }
    para.push(line);
  }
  return para
    .join(' ')
    .replace(/\s+/g, ' ')
    .replace(/\*\*(.+?)\*\*/g, '$1')
    .replace(/\*(.+?)\*/g, '$1')
    .replace(/`([^`]+)`/g, '$1')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .trim();
}
const lede = pfScenario
  ? scenarioParagraph(pfScenario.content)
  : bodyExcerpt(entry.body);

interface SubApproachYaml {
  maturity?: string;
  context?: string;
  crops?: { cr?: string; o?: string; p?: string; s?: string };
  uses_patterns?: string[];
  poc_spec?: string;
  example_vendors?: string[];
}

interface SubApproach {
  name: string;
  id: string;
  yaml: SubApproachYaml;
  summary: string;
  howItWorks: string;
  trustAssumptions: string;
  threatModel: string;
  worksBestWhen: string;
  avoidWhen: string;
  implementationNotes: string;
  benchmarksContent: string;
}

function slugify(s: string) {
  return s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

function parseSubApproach(name: string, content: string): SubApproach {
  const yamlText = extractYamlBlock(content);
  let yamlData: SubApproachYaml = {};
  try {
    yamlData = yamlText ? (yaml.load(yamlText) as SubApproachYaml) || {} : {};
  } catch {
    yamlData = {};
  }
  const withoutYaml = content.replace(/```yaml\s*\n[\s\S]*?\n```/, '').trim();
  const benchMatch = withoutYaml.match(/#### Benchmarks\s*\n([\s\S]*?)(?=\n####|\n###|$)/);
  return {
    name,
    id: slugify(name),
    yaml: yamlData,
    summary: extractLabelledBlock(withoutYaml, 'Summary'),
    howItWorks: extractLabelledBlock(withoutYaml, 'How it works'),
    trustAssumptions: extractLabelledBlock(withoutYaml, 'Trust assumptions'),
    threatModel: extractLabelledBlock(withoutYaml, 'Threat model'),
    worksBestWhen: extractLabelledBlock(withoutYaml, 'Works best when'),
    avoidWhen: extractLabelledBlock(withoutYaml, 'Avoid when'),
    implementationNotes: extractLabelledBlock(withoutYaml, 'Implementation notes'),
    benchmarksContent: benchMatch ? benchMatch[1].trim() : '',
  };
}

const subApproaches = approachesSec
  ? parseSubSections(approachesSec.content).map((s) => parseSubApproach(s.heading, s.content))
  : [];

// Persona tabs — keep heading text minus trailing "perspective".
const personaSubs = personas ? parseSubSections(personas.content) : [];
const personaList = personaSubs.map((s) => ({
  key: s.key,
  label: s.heading.replace(/\s*perspective\s*$/i, '').trim(),
  content: s.content,
}));

// Recommendation → Default / Decision factors / Hybrid
const recSubs = recommendation ? parseSubSections(recommendation.content) : [];
const recDefault = recSubs.find((s) => s.key === 'default');
const recDecision = recSubs.find((s) => s.key === 'decision-factors');
const recHybrid = recSubs.find((s) => s.key === 'hybrid');

// Sidebar data — primary/supporting patterns and vendors from sub-approach yaml
const allPatterns = await getCollection('patterns');
const allVendors = await getCollection('vendors');
const allUseCases = useCases;

function patternBySlug(slug: string) {
  const stripped = slug.startsWith('pattern-') ? slug.slice('pattern-'.length) : slug;
  return allPatterns.find(
    (p) => p.id === stripped || p.id === slug || p.id === `pattern-${stripped}`,
  );
}

const primaryPatternList = (entry.data.primary_patterns ?? [])
  .map(patternBySlug)
  .filter(Boolean) as typeof allPatterns;

const supportingPatternList = (entry.data.supporting_patterns ?? [])
  .map(patternBySlug)
  .filter(Boolean) as typeof allPatterns;

const vendorRoles: Record<string, { role: string; title: string; slug: string }> = {};
for (const sub of subApproaches) {
  for (const v of sub.yaml.example_vendors ?? []) {
    const target = allVendors.find((vn) => vn.id === v);
    if (target && !vendorRoles[v]) {
      vendorRoles[v] = {
        role: sub.name,
        title: stripTypePrefix(target.data.title),
        slug: target.id,
      };
    }
  }
}

const relatedUseCases = (entry.data.related_use_cases ?? [])
  .map((slug) => allUseCases.find((uc) => uc.id === slug))
  .filter(Boolean) as typeof allUseCases;

// Rail-only data. The cross-graph ArticleFooter ("Continue reading"
// cards) was removed on approach detail to reduce link duplication —
// the sidebar's frontmatter-driven Building blocks / Vendors / Use
// cases + Referenced by panels already cover navigation needs for
// this content type.
const referencedBy = await getReferencedBy('approaches', entry.id);

// Maturity tone → reuse our variant maturity vocabulary.
function maturityTone(m?: string): 'strong' | 'mid' | 'plain' | 'muted' {
  if (!m) return 'muted';
  const v = m.toLowerCase();
  if (v === 'production' || v === 'benchmarked') return 'strong';
  if (v === 'prototyped' || v === 'implemented') return 'mid';
  if (v === 'documented' || v === 'spec-only') return 'plain';
  return 'muted';
}

---

<DetailPageLayout
  title={title}
  pageTitle={title}
  description={lede}
  current="/approaches/"
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Approaches', href: '/approaches/' },
    { label: title },
  ]}
  lede={lede}
>
  <div class="approach-main">

    {personaList.length > 0 && (
      <div class="persona-block">
        <div class="persona-tabs" role="tablist">
          {personaList.map((p, i) => (
            <button
              type="button"
              class={`persona-tab ${i === 0 ? 'active' : ''}`}
              data-persona={p.key}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            >{p.label}</button>
          ))}
        </div>
        {personaList.map((p, i) => (
          <div
            class={`persona-panel ${i === 0 ? 'active' : ''}`}
            data-persona={p.key}
          >
            <div class="prose" set:html={renderMarkdown(p.content)} />
          </div>
        ))}
      </div>
    )}

    {/* Scenario is lifted into the hero lede above, so don't render it
        again here. Requirements + Constraints still belong in the body
        because they're bullet lists, not narrative paragraphs. */}
    {(pfRequirements || pfConstraints) && (
      <section class="approach-section">
        {pfRequirements && (
          <>
            <h2>Requirements</h2>
            <div class="prose" set:html={renderMarkdown(pfRequirements.content)} />
          </>
        )}
        {pfConstraints && (
          <>
            <h2>Constraints</h2>
            <div class="prose" set:html={renderMarkdown(pfConstraints.content)} />
          </>
        )}
      </section>
    )}

    {subApproaches.length > 0 && (
      <section class="approach-section">
        <h2>Architectural options</h2>

        {recDefault && (
          <div class="recommended">
            <h4>Recommended</h4>
            <div class="prose" set:html={renderMarkdown(recDefault.content)} />
          </div>
        )}

        <div class="approach-options">
          {subApproaches.map((sub) => {
            const hasDetail =
              sub.howItWorks ||
              sub.trustAssumptions ||
              sub.threatModel ||
              sub.worksBestWhen ||
              sub.avoidWhen ||
              sub.implementationNotes ||
              sub.benchmarksContent;

            const headerInner = (
              <>
                <div class="approach-option-head">
                  <div class="approach-option-titlecol">
                    <h4>{sub.name}</h4>
                    {sub.yaml.maturity && (
                      <span class={`mat-pill mat-${maturityTone(sub.yaml.maturity)}`}>
                        {sub.yaml.maturity}
                      </span>
                    )}
                  </div>
                  {sub.yaml.crops && (
                    <CropsPie profile={sub.yaml.crops} size={52} />
                  )}
                  {hasDetail && <span class="approach-option-toggle" aria-hidden="true"></span>}
                </div>
                {sub.summary && <p class="approach-option-summary">{sub.summary}</p>}
              </>
            );

            return hasDetail ? (
              <details class="approach-option" id={sub.id}>
                <summary>{headerInner}</summary>
                <div class="approach-option-body">
                  {sub.howItWorks && (
                    <div class="block">
                      <h5>How it works</h5>
                      <div class="prose" set:html={renderMarkdown(sub.howItWorks)} />
                    </div>
                  )}
                  <div class="block-grid">
                    {sub.trustAssumptions && (
                      <div class="block">
                        <h5>Trust assumptions</h5>
                        <div class="prose" set:html={renderMarkdown(sub.trustAssumptions)} />
                      </div>
                    )}
                    {sub.threatModel && (
                      <div class="block">
                        <h5>Threat model</h5>
                        <div class="prose" set:html={renderMarkdown(sub.threatModel)} />
                      </div>
                    )}
                    {sub.worksBestWhen && (
                      <div class="block block-good">
                        <h5>Works best when</h5>
                        <div class="prose" set:html={renderMarkdown(sub.worksBestWhen)} />
                      </div>
                    )}
                    {sub.avoidWhen && (
                      <div class="block block-bad">
                        <h5>Avoid when</h5>
                        <div class="prose" set:html={renderMarkdown(sub.avoidWhen)} />
                      </div>
                    )}
                  </div>
                  {sub.implementationNotes && (
                    <div class="block">
                      <h5>Implementation notes</h5>
                      <div class="prose" set:html={renderMarkdown(sub.implementationNotes)} />
                    </div>
                  )}
                  {sub.benchmarksContent && (
                    <div class="block">
                      <h5>Benchmarks</h5>
                      <div class="prose table-wrap" set:html={renderMarkdown(sub.benchmarksContent)} />
                    </div>
                  )}
                </div>
              </details>
            ) : (
              <article class="approach-option approach-option--flat" id={sub.id}>
                {headerInner}
              </article>
            );
          })}
        </div>
      </section>
    )}

    {comparison && (
      <section class="approach-section">
        <h2>Side-by-side</h2>
        {/* Strip the redundant CROPS table row — already shown as pills above. */}
        <div
          class="prose table-wrap"
          set:html={String(renderMarkdown(comparison.content)).replace(
            /<tr>\s*<td><strong>CROPS<\/strong><\/td>[\s\S]*?<\/tr>/i,
            '',
          )}
        />
      </section>
    )}

    {(recDecision || recHybrid) && (
      <section class="approach-section">
        {recDecision && (
          <>
            <h2>Decision factors</h2>
            <div class="prose" set:html={renderMarkdown(recDecision.content)} />
          </>
        )}
        {recHybrid && (
          <>
            <h2>Hybrid composition</h2>
            <div class="prose" set:html={renderMarkdown(recHybrid.content)} />
          </>
        )}
      </section>
    )}

    {openQuestions && (
      <details class="approach-collapsible open-questions">
        <summary><span class="coll-name">Open questions</span></summary>
        <div class="coll-content">
          <div class="prose" set:html={renderMarkdown(openQuestions.content)} />
        </div>
      </details>
    )}

    {exampleScenario && exampleScenario.key !== 'problem-framing' && (
      <section class="approach-section">
        <div class="prose" set:html={renderMarkdown(exampleScenario.content)} />
      </section>
    )}

    {referencedBy.length > 0 && (
      <section class="approach-backrefs">
        <h4 class="backref-title">Referenced by</h4>
        <div class="backref-grid">
          {referencedBy.map((group) => {
            const subheading = group.heading.replace(/^Referenced by /, '');
            return (
              <div class="backref-group">
                <h5>{subheading}</h5>
                <ul>
                  {group.items.map((it) => (
                    <li><a href={it.href}>{it.label}</a></li>
                  ))}
                </ul>
              </div>
            );
          })}
        </div>
      </section>
    )}

    {lastReviewed && (
      <p class="approach-last-reviewed">
        <span>Last reviewed</span>
        <time>{lastReviewed}</time>
      </p>
    )}
  </div>

  <Fragment slot="rail">
    <aside class="approach-rail">
      {(primaryPatternList.length > 0 || supportingPatternList.length > 0) && (
        <details class="rail-section" open>
          <summary class="rail-label">
            <span>Building blocks</span>
            <span class="rail-count">{primaryPatternList.length + supportingPatternList.length}</span>
          </summary>
          {primaryPatternList.length > 0 && (
            <>
              <div class="rail-sublabel">Primary</div>
              {primaryPatternList.map((p) => (
                <a href={`/patterns/${p.id}/`} class="rail-pattern">
                  <span class="rail-dot rail-dot-core" aria-hidden="true"></span>
                  <span class="rail-pattern-name">{stripTypePrefix(p.data.title)}</span>
                </a>
              ))}
            </>
          )}
          {supportingPatternList.length > 0 && (
            <>
              <div class="rail-sublabel">Supporting</div>
              {supportingPatternList.slice(0, 5).map((p) => (
                <a href={`/patterns/${p.id}/`} class="rail-pattern">
                  <span class="rail-dot rail-dot-support" aria-hidden="true"></span>
                  <span class="rail-pattern-name">{stripTypePrefix(p.data.title)}</span>
                </a>
              ))}
              {supportingPatternList.length > 5 && (
                <details class="rail-more">
                  <summary>+{supportingPatternList.length - 5} more</summary>
                  {supportingPatternList.slice(5).map((p) => (
                    <a href={`/patterns/${p.id}/`} class="rail-pattern">
                      <span class="rail-dot rail-dot-support" aria-hidden="true"></span>
                      <span class="rail-pattern-name">{stripTypePrefix(p.data.title)}</span>
                    </a>
                  ))}
                </details>
              )}
            </>
          )}
        </details>
      )}

      {Object.keys(vendorRoles).length > 0 && (
        <details class="rail-section">
          <summary class="rail-label">
            <span>Vendors</span>
            <span class="rail-count">{Object.keys(vendorRoles).length}</span>
          </summary>
          {Object.values(vendorRoles).map((vr) => (
            <a class="rail-vendor" href={`/vendors/${vr.slug}/`}>
              <div class="rail-vendor-name">{vr.title}</div>
              <div class="rail-vendor-role">{vr.role}</div>
            </a>
          ))}
        </details>
      )}

      {relatedUseCases.length > 0 && (
        <details class="rail-section">
          <summary class="rail-label">
            <span>Related use cases</span>
            <span class="rail-count">{relatedUseCases.length}</span>
          </summary>
          {relatedUseCases.map((uc) => (
            <a href={`/use-cases/${uc.id}/`} class="rail-link">
              {stripTypePrefix(uc.data.title)}
            </a>
          ))}
        </details>
      )}

      {entry.data.iptf_pocs && Array.isArray(entry.data.iptf_pocs.pocs) && entry.data.iptf_pocs.pocs.length > 0 && (
        <details class="rail-section">
          <summary class="rail-label">
            <span>IPTF prototypes</span>
            <span class="rail-count">{entry.data.iptf_pocs.pocs.length}</span>
          </summary>
          {entry.data.iptf_pocs.pocs.map((poc: any) => (
            <div class="rail-poc">
              <div class="rail-poc-name">{poc.name}</div>
              {poc.sub_approach && (
                <div class="rail-poc-sub">For: {poc.sub_approach}</div>
              )}
              {poc.status && (
                <span class={`rail-poc-pill mat-${maturityTone(poc.status)}`}>{poc.status}</span>
              )}
            </div>
          ))}
        </details>
      )}

      {entry.data.open_source_implementations && entry.data.open_source_implementations.length > 0 && (
        <details class="rail-section">
          <summary class="rail-label">
            <span>Open-source</span>
            <span class="rail-count">{entry.data.open_source_implementations.length}</span>
          </summary>
          {entry.data.open_source_implementations.map((impl: any) => (
            <a href={impl.url} target="_blank" rel="noopener noreferrer" class="rail-oss">
              <div class="rail-oss-desc">{impl.description || impl.url}</div>
              {impl.language && <div class="rail-oss-lang">{impl.language}</div>}
            </a>
          ))}
        </details>
      )}
    </aside>
  </Fragment>
</DetailPageLayout>

{personaList.length > 0 && (
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var tabs = document.querySelectorAll('.persona-tab');
      var panels = document.querySelectorAll('.persona-panel');
      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          var target = this.getAttribute('data-persona');
          tabs.forEach(function (t) {
            t.classList.remove('active');
            t.setAttribute('aria-selected', 'false');
          });
          this.classList.add('active');
          this.setAttribute('aria-selected', 'true');
          panels.forEach(function (p) {
            p.classList.toggle('active', p.getAttribute('data-persona') === target);
          });
        });
      });
    });
  </script>
)}

<style>
  .approach-main { min-width: 0; }

  /* Incoming "Referenced by" — moved out of the sidebar (locked rail
     IA change) to a single dashed-border block at the end of the
     article. Multi-column when there are >1 group so case-studies /
     use-cases / patterns sit side by side rather than stacking. */
  .approach-backrefs {
    margin-top: 3rem;
    padding: 1.1rem 1.25rem 1.2rem;
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
  }
  .backref-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 0.85rem;
  }
  .backref-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .backref-group h5 {
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-secondary);
    margin: 0 0 0.45rem;
    text-transform: lowercase;
    letter-spacing: 0;
  }
  .backref-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .backref-group li::marker { content: ''; }
  .backref-group a {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    font-size: 0.86rem;
    font-weight: 500;
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--easing-soft);
  }
  .backref-group a::before {
    content: '→';
    color: var(--color-cta);
    font-weight: 700;
  }
  .backref-group a:hover { color: var(--color-cta); }

  /* Tiny end-of-article timestamp where the cross-graph footer used
     to sit. Kept deliberately quiet — the sidebar carries the heavy
     navigation. */
  .approach-last-reviewed {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .approach-last-reviewed span {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
  .approach-last-reviewed time {
    color: var(--color-text-secondary);
  }

  /* ─── Persona tabs ─────────────────────────────────────────── */
