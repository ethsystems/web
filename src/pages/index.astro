---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroMark from '../components/HeroMark.astro';
import SupportedBy from '../components/SupportedBy.astro';
import MarkDither from '../components/MarkDither.astro';
import { site } from '../lib/site';
import { getStats } from '../lib/stats';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import { jekyllSlugify } from '../lib/jekyllSlug';
import { isPublished } from '../lib/posts';
import { findFaq } from '../data/faq';

const stats = await getStats();

// Top 3 long-form posts from the posts collection (src/posts/). Sorted
// newest first by frontmatter date.
function toISODate(d: string | Date | undefined): string {
  if (!d) return '';
  if (d instanceof Date) return d.toISOString().slice(0, 10);
  return String(d).slice(0, 10);
}
const allPosts = await getCollection('posts');
const latestPosts = allPosts
  .filter((p) => isPublished(p))
  .map((p) => ({
    slug: jekyllSlugify(p.data.title),
    title: p.data.title,
    description: p.data.description ?? '',
    date: toISODate(p.data.date),
    image: p.data.image,
  }))
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 3);

// FAQ teaser — 9 hand-curated featured questions resolved against the
// shared FAQ dataset (src/data/faq.ts). The homepage renders these inline
// as expandable accordions so the full answer is one click away without a
// page jump. Strings must match faq.ts exactly (findFaq is strict equality).
const FEATURED_FAQ_QS = [
  'What is Ethereum Systems?',
  'Who is behind it?',
  'What have you actually built?',
  'Why does this matter?',
  'What do you offer institutions?',
  "What's your relationship with the Ethereum Foundation?",
  'How do you relate to Ethlabs and Ethereum Institutional?',
  'Is your work open source?',
  'Where do you operate?',
];
const faqTeasers = FEATURED_FAQ_QS
  .map((q) => findFaq(q))
  .filter((e): e is NonNullable<typeof e> => e !== undefined);
---

<BaseLayout title="" description="A working knowledge base for institutional privacy on Ethereum." current="/">

  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-inner">
        <h1>Confidential Systems for Institutional Ethereum</h1>
        <p class="lede"><strong>Ethereum Systems</strong> helps institutions move on-chain with privacy that's performant, secure, usable, and accessible, disclosing only what the rules require.</p>
        <div class="cta-row">
          <a href="/approaches/" class="btn primary lg">See approaches<span class="arr">→</span></a>
          <a href="/blog/" class="btn ghost lg">See writeups<span class="arr">→</span></a>
        </div>
      </div>
      <div class="hero-mark-col" aria-hidden="true">
        <HeroMark />
      </div>
    </div>
  </section>

  <!-- NARRATIVE — the launch story in one passage. The words institutions
       cannot reveal are sealed under ink redaction bars (the hero mark's
       own vocabulary) and lift as the section scrolls into view: the copy
       performs selective disclosure. Pure CSS scroll-driven animation;
       resting state (no support, reduced motion) is the revealed text. -->
  <section class="narrative">
    <div class="container">
      <p class="kicker narrative-kicker">The team institutions already know</p>
      <p class="narrative-prose">
        Institutions want to move real financial activity onto Ethereum.
        A public ledger exposes <span class="redact" style="--i:0"><span class="redact-word">positions,</span></span> <span class="redact" style="--i:1"><span class="redact-word">counterparties,</span></span> and <span class="redact" style="--i:2"><span class="redact-word">flows</span></span> they are not allowed to reveal.
      </p>
      <p class="narrative-body">
        <strong>Ethereum Systems</strong>, the team behind the Ethereum Foundation&rsquo;s Institutional Privacy Task Force, builds the confidential, compliant systems that make that possible, from proof-of-concept through to production, backed by a year of open-source work already shipped.
      </p>
    </div>
  </section>

  <!-- READING PATHS -->
  <section class="block">
    <div class="container">
      <div class="section-head">
        <h2>Find the right privacy solution</h2>
        <p class="meta">We document patterns, use cases, and regulatory frameworks for implementing privacy-preserving financial applications on Ethereum.</p>
      </div>

      <div class="paths">
        <a class="path" href="/approaches/">
          <div class="path-content">
            <h3>Approaches</h3>
            <p>Read worked architectures directly. Each names trade-offs in plain language, evaluates under CROPS, and references a working prototype where one exists.</p>
            <span class="path-link"><strong>{stats.approaches}</strong> approaches <span class="arr">→</span></span>
          </div>
        </a>

        <a class="path" href="/use-cases/">
          <div class="path-content">
            <h3>Problem areas</h3>
            <p>Begin from the institutional question that mirrors your situation. Each use case pairs with one or more approaches that demonstrate how others have built solutions.</p>
            <span class="path-link"><strong>{stats.useCases}</strong> use cases <span class="arr">→</span></span>
          </div>
        </a>

        <a class="path" href="/patterns/">
          <div class="path-content">
            <h3>Reusable solutions</h3>
            <p>Build your own approach using the cryptographic primitives applied in our case studies. Each building block includes its risk profile, architectural layer, and trade-offs.</p>
            <span class="path-link"><strong>{stats.patterns}</strong> building blocks <span class="arr">→</span></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- WHO IS THIS FOR -->
  <section class="glance">
    <div class="container">
      <div class="section-head">
        <h2>Who is this for</h2>
        <p class="meta">Ethereum Systems coordinates between vendors and protocols, institutions, and regulators. The map and the approaches are written so each group can reach the same evidence by a different door. Pick the column that fits your role; each one is a recommended reading order, not a forced path.</p>
      </div>

      <div class="persona-grid">
        <div class="persona">
          <div class="persona-head">
            <span class="persona-eyebrow">For business stakeholders</span>
            <p class="persona-purpose">Decide what to integrate.</p>
          </div>
          <ol class="persona-rail">
            <li>
              <a href="/use-cases/">
                <span class="persona-num">01</span>
                <span class="persona-body">
                  <span class="persona-label">Use cases</span>
                  <span class="persona-hint">Start with business requirements and challenges.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
            <li>
              <a href="/jurisdictions/">
                <span class="persona-num">02</span>
                <span class="persona-body">
                  <span class="persona-label">Jurisdictions</span>
                  <span class="persona-hint">Regulatory considerations in the regions you operate in.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
            <li>
              <a href="/approaches/">
                <span class="persona-num">03</span>
                <span class="persona-body">
                  <span class="persona-label">Approaches</span>
                  <span class="persona-hint">Recommended architectures with named trade-offs.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
          </ol>
        </div>

        <div class="persona">
          <div class="persona-head">
            <span class="persona-eyebrow">For technical teams</span>
            <p class="persona-purpose">Decide how to build.</p>
          </div>
          <ol class="persona-rail">
            <li>
              <a href="/patterns/">
                <span class="persona-num">01</span>
                <span class="persona-body">
                  <span class="persona-label">Building blocks</span>
                  <span class="persona-hint">Reusable technical building blocks with standardized evaluations.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
            <li>
              <a href="/approaches/">
                <span class="persona-num">02</span>
                <span class="persona-body">
                  <span class="persona-label">Approaches</span>
                  <span class="persona-hint">Detailed implementation guidance from worked approaches.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
            <li>
              <a href="/vendors/">
                <span class="persona-num">03</span>
                <span class="persona-body">
                  <span class="persona-label">Vendors</span>
                  <span class="persona-hint">Tooling and infrastructure options mapped to patterns.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
            <li>
              <a href="/domains/">
                <span class="persona-num">04</span>
                <span class="persona-body">
                  <span class="persona-label">Domains</span>
                  <span class="persona-hint">Domain-specific considerations across payments, custody, identity, and more.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
          </ol>
        </div>

        <div class="persona">
          <div class="persona-head">
            <span class="persona-eyebrow">For legal and compliance</span>
            <p class="persona-purpose">Map regulatory requirements.</p>
          </div>
          <ol class="persona-rail">
            <li>
              <a href="/jurisdictions/">
                <span class="persona-num">01</span>
                <span class="persona-body">
                  <span class="persona-label">Jurisdictions</span>
                  <span class="persona-hint">Regulatory frameworks applied as overlay on the architectures.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
            <li>
              <a href="/use-cases/">
                <span class="persona-num">02</span>
                <span class="persona-body">
                  <span class="persona-label">Use cases</span>
                  <span class="persona-hint">Compliance constraints surfaced in context, written from interview.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
            <li>
              <a href="/approaches/">
                <span class="persona-num">03</span>
                <span class="persona-body">
                  <span class="persona-label">Approaches</span>
                  <span class="persona-hint">Architectures evaluated for regulated deployment.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
            <li>
              <a href="/patterns/pattern-regulatory-disclosure-keys-proofs/">
                <span class="persona-num">04</span>
                <span class="persona-body">
                  <span class="persona-label">Disclosure mechanisms</span>
                  <span class="persona-hint">Selective disclosure with keys and proofs for audit and reporting.</span>
                </span>
                <span class="arr">→</span>
              </a>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- WRITEUPS — moved above the assessment framework per 2026-05-22 meeting:
       Oscar wanted writeups higher / more first-class. -->
  {latestPosts.length > 0 && (
    <section class="block">
      <div class="container">
        <div class="section-head">
          <h2>Recent writeups from the team</h2>
          <p class="meta">Long-form research, guides, POCs, and analysis from the Ethereum Systems team.</p>
        </div>

        <div class="writeups">
          {latestPosts.map((p) => (
            <a class="writeup" href={`/blog/${p.slug}/`}>
              <div class="writeup-thumb">
                {p.image ? (
                  <Image src={p.image} alt="" width={800} format="webp" loading="lazy" />
                ) : (
                  <svg viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                    <defs>
                      <linearGradient id={`wr-${p.slug}`} x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0" style="stop-color:var(--color-cta)"/>
                        <stop offset="1" style="stop-color:var(--color-primary)"/>
                      </linearGradient>
                    </defs>
                    <rect width="100" height="100" fill={`url(#wr-${p.slug})`}/>
                  </svg>
                )}
              </div>
              <div class="writeup-body">
                {p.date && <div class="writeup-meta"><span>{p.date}</span></div>}
                <h4>{p.title}</h4>
                {p.description && <p>{p.description}</p>}
              </div>
            </a>
          ))}
        </div>

        <div class="see-all-row">
          <a href="/blog/">See all writeups<span class="arr">→</span></a>
        </div>
      </div>
    </section>
  )}

  <section class="block home-crops">
    <div class="container">
      <div class="section-head">
        <h2>How we assess solutions</h2>
        <p class="meta">Every pattern on this site is rated against four properties (the CROPS framework) and tagged for the institutional context it fits.</p>
      </div>
      <div class="crops-grid">
        <div class="crops-axis">
          <span class="crops-axis-code">CR</span>
          <h3>Censorship-resistance</h3>
          <p>Whether a counterparty, sequencer, or relayer can block your transaction.</p>
        </div>
        <div class="crops-axis">
          <span class="crops-axis-code">OS</span>
          <h3>Open source</h3>
          <p>Whether the implementation is free to audit, fork, and self-host.</p>
        </div>
        <div class="crops-axis">
          <span class="crops-axis-code">P</span>
          <h3>Privacy</h3>
          <p>How much of the transaction (amounts, parties, patterns) stays hidden.</p>
        </div>
        <div class="crops-axis">
          <span class="crops-axis-code">S</span>
          <h3>Security</h3>
          <p>The trust assumptions and threat model the architecture relies on.</p>
        </div>
      </div>
      <div class="b2b-b2c-grid">
        <div class="b2x-card">
          <div class="b2x-label">Institution to institution</div>
          <p>Both counterparties are regulated institutions. Symmetric power dynamic; both parties have legal teams, vendor choice, and contractual recourse.</p>
        </div>
        <div class="b2x-card">
          <div class="b2x-label">Institution to user</div>
          <p>One counterparty is a regulated institution, the other an individual. Asymmetric power dynamic; privacy must protect the user from the institution.</p>
        </div>
      </div>
      <div class="home-crops-cta-row">
        <a href="/patterns/" class="home-crops-cta">Browse the patterns<span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- SUPPORTED BY — coalition tier row, between hero and reading paths. -->
  <SupportedBy />


  <!-- HOME-FAQ — paired with MarkDither on the right so the
       diamond visual carries some of the section's weight and the FAQ
       column doesn't stretch the full container width. -->

  <section class="block home-faq">
    <div class="container">
      <div class="home-faq-grid">
        <div class="home-faq-content">
          <div class="section-head">
            <h2>What institutions ask us most</h2>
            <p class="meta">The questions we hear most, answered directly. Each one links into the full FAQ where answers cite the relevant pattern, jurisdiction, and approach.</p>
          </div>
          <div class="home-faq-list">
            {faqTeasers.map((item) => (
              <details class="home-faq-item" name="home-faq">
                <summary>
                  <span class="home-faq-q">{item.q}</span>
                  <span class="home-faq-toggle" aria-hidden="true"></span>
                </summary>
                <div class="home-faq-a">
                  {item.a.map((p) => (
                    <p>{p}</p>
                  ))}
                  {item.links && item.links.length > 0 && (
                    <div class="home-faq-links">
                      {item.links.map((link) => (
                        <a href={link.href} class="home-faq-link">
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                            <path d="M5 12h14" />
                            <path d="M12 5l7 7-7 7" />
                          </svg>
                          {link.label}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
              </details>
            ))}
          </div>
          <a href="/faq/" class="home-faq-cta">Read all FAQs<span class="arr">→</span></a>
        </div>
        <div class="home-faq-visual" aria-hidden="true">
          <MarkDither />
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT — final section before the footer per IA decision. -->
  <section class="contact">
    <div class="container">
      <div class="contact-grid">
        <div>
          <h2>Talk to Ethereum Systems</h2>
          <div class="contact-body">
            <p>If you are an institution with a privacy requirement, a builder shipping a solution, or a regulator who wants the picture, we are listening.</p>
          </div>
        </div>
        <div class="contact-options">
          <a href={site.contactFormUrl} class="contact-option" target="_blank" rel="noopener noreferrer">
            <span class="contact-option-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg></span>
            <div>
              <h4>Contact us</h4>
              <p>Tell us about your requirements and the team will follow up.</p>
            </div>
            <span class="arr">→</span>
          </a>
          <a href={`mailto:${site.email}`} class="contact-option">
            <span class="contact-option-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
            <div>
              <h4>{site.email}</h4>
              <p>General correspondence with the team.</p>
            </div>
            <span class="arr">→</span>
          </a>
          <a href={site.mapRepo} class="contact-option">
            <span class="contact-option-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg></span>
            <div>
              <h4>GitHub · map</h4>
              <p>Open issues, propose patterns, contribute use cases.</p>
            </div>
            <span class="arr">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO — two columns on desktop (copy left, ledger mark right); single
     column on mobile with the mark below the copy. */
  .hero {
    padding: 5.5rem 0 5rem;
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 640px;
    text-align: left;
  }
  .hero-kicker { margin-bottom: 1.25rem; }
  .hero h1 {
    font-family: var(--font-display);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 0, "WONK" 0;
    font-size: clamp(2.6rem, 5.2vw, 3.9rem);
    line-height: 1.04;
    letter-spacing: -0.015em;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    max-width: 16ch;
  }
  .hero .lede {
    font-size: var(--fs-lead);
    line-height: 1.5;
    color: var(--color-text-secondary);
    max-width: 40ch;
    margin-bottom: 2rem;
  }
  .hero .lede strong { color: var(--color-primary); font-weight: 600; }
  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }
  /* Mobile: mark sits below the copy, centered. */
  .hero-mark-col {
    width: min(80vw, 340px);
    margin: 1rem auto 0;
  }
  @media (max-width: 720px) {
    .hero { padding: 3rem 0 3.5rem; }
    .hero .lede { font-size: 1.05rem; margin-bottom: 1.5rem; }
    /* Float the ledger mark above the copy on mobile — `order` reorders
       the stacked grid items so the animation leads, then the copy
       (kicker, "Confidential Systems…" h1, lede, CTAs) follows. The
       grid's row `gap` handles the spacing, so drop the mark's own
       top margin. */
    .hero-mark-col { order: -1; margin: 0 auto; }
  }
  @media (min-width: 920px) {
    /* Fill the first viewport exactly: 100svh minus the sticky nav
       (30px logo + 2 x 0.95rem padding + 1px border = 62px), so the
       hero owns the whole screen on load and the fold lands on its
       bottom border. */
    .hero { padding: 4rem 0; min-height: calc(100svh - 62px); display: grid; align-items: center; }
    .hero-grid {
      grid-template-columns: minmax(0, 56fr) minmax(0, 44fr);
      gap: clamp(2rem, 5vw, 4rem);
    }
    .hero-mark-col {
      width: auto;
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }

  /* NARRATIVE — redacted prose. The bars are ink rectangles drawn by the
     .redact::after pseudo-element over each word. Two states:
       resting (no scroll-driven-animation support / reduced motion):
         bars at scaleX(0), words visible.
       supported + motion allowed: bars armed at scaleX(1), then a
         scroll-driven animation on the section's view timeline wipes
         each bar toward its right edge, uncovering the word left-to-
         right in reading order, staggered by --i. Scrubs with scroll
         (reverses on scroll-up) — unlike the old one-shot JS observer.
     Ink on paper only; no navy, no fades over gaps. */
  .narrative {
    padding: 6.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .narrative-kicker { margin-bottom: 1.75rem; }
  .narrative-prose {
    font-family: var(--font-display);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 0, "WONK" 0;
    font-size: clamp(1.6rem, 1.15rem + 2.2vw, 2.7rem);
    line-height: 1.28;
    letter-spacing: -0.012em;
    color: var(--color-primary);
    max-width: 30ch;
    margin: 0 0 1.75rem;
  }
  .narrative-body {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 58ch;
    margin: 0;
  }
  .narrative-body strong {
    color: var(--color-primary);
    font-weight: 600;
  }
  .redact {
    position: relative;
    white-space: nowrap;
  }
  .redact::after {
    content: '';
    position: absolute;
    inset: 0.02em -0.09em -0.06em;
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: 100% 50%;
    pointer-events: none;
  }
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .narrative { view-timeline: --narrative-reveal block; }
      .redact::after {
        transform: scaleX(1);
        animation: redact-lift linear both;
        animation-timeline: --narrative-reveal;
        /* First bar starts lifting once ~40% of the section has entered
           the viewport; each later word trails by 10% of the entry range
           so the wipe reads left-to-right. */
        animation-range: entry calc(40% + var(--i) * 10%)
          entry calc(100% + var(--i) * 5%);
      }
    }
  }
  @keyframes redact-lift {
    from { transform: scaleX(1); }
    to { transform: scaleX(0); }
  }
  @media (max-width: 720px) {
    .narrative { padding: 4rem 0; }
  }

  /* ABOUT */
  .about-section {
    padding: 5rem 0;
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }
  .about-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 64ch;
  }
  .about-grid h2 {
    font-family: var(--font-display);
    font-weight: 420;
    font-variation-settings: "opsz" 144, "SOFT" 0, "WONK" 0;
    font-size: clamp(2.15rem, 3.8vw, 3rem);
    line-height: 1.06;
    letter-spacing: -0.012em;
    color: var(--color-primary);
    max-width: 22ch;
    margin-bottom: 0.5rem;
  }
  .about-grid .body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    max-width: 64ch;
  }
  .about-grid .body p { margin-bottom: 1rem; }
  .about-grid .body p:last-child { margin-bottom: 0; }
  .about-grid .body strong { color: var(--color-primary); font-weight: 600; }

  /* READING PATHS */
  .paths {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 800px) { .paths { grid-template-columns: 1fr; } }
  .path {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem 2rem;
    background: var(--color-bg-card);
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-text);
    transition: transform var(--duration-base) var(--easing-soft),
                box-shadow var(--duration-base) var(--easing-soft),
                border-color var(--duration-base) var(--easing-soft);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    min-height: 300px;
  }
  .path:hover {
    border-color: var(--color-cta);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .path::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    height: 3px;
    width: 0;
    background: var(--color-cta);
    transition: width var(--duration-slow) var(--easing-soft);
  }
  .path:hover::after { width: 100%; }
  .path-content { display: flex; flex-direction: column; gap: 0.75rem; min-width: 0; flex: 1; }
  .path h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-variation-settings: "opsz" 144, "SOFT" 0, "WONK" 0;
    font-size: 1.95rem;
    letter-spacing: -0.012em;
    line-height: 1.06;
    color: var(--color-primary);
  }
  .path p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .path-link {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-cta);
    /* Pin to the bottom of .path-content so the three CTAs line up
       on the same row across cards regardless of body length. */
    margin-top: auto;
    padding-top: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .path-link .arr { transition: transform var(--duration-fast) var(--easing-soft); }
  .path:hover .path-link .arr { transform: translateX(3px); }

  /* WHO IS THIS FOR */
  .glance {
    padding: 8rem 0;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-subtle);
  }
  .persona-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-top: 3rem;
  }
  @media (max-width: 900px) {
    .persona-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  .persona {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    min-width: 0;
  }
  .persona + .persona {
    border-left: 1px solid var(--color-border);
    padding-left: 3rem;
  }
  @media (max-width: 900px) {
    .persona + .persona {
      border-left: none;
      border-top: 1px solid var(--color-border);
      padding-left: 0;
      padding-top: 2.5rem;
    }
  }
  .persona-head {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .persona-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-weight: 600;
  }
  .persona-purpose {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: -0.018em;
    line-height: 1.2;
    color: var(--color-primary);
    margin: 0;
  }
  .persona-rail {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
  }
  .persona-rail::before {
    content: '';
    position: absolute;
    left: 13.5px;
    top: calc(0.85rem + 14px);
    bottom: calc(0.85rem + 14px);
    width: 1px;
    background: var(--color-border-strong);
    z-index: 0;
  }
  .persona-rail li {
    position: relative;
    z-index: 1;
  }
  .persona-rail a {
    display: grid;
    grid-template-columns: 28px 1fr 14px;
    gap: 0.9rem;
    align-items: start;
    padding: 0.85rem 0;
    text-decoration: none;
    color: var(--color-text);
  }
  .persona-num {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    transition: background var(--duration-fast) var(--easing-soft),
                color var(--duration-fast) var(--easing-soft),
                border-color var(--duration-fast) var(--easing-soft);
    flex-shrink: 0;
  }
  .persona-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .persona-label {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-primary);
    letter-spacing: -0.015em;
    line-height: 1.3;
  }
  .persona-hint {
    font-size: 13.5px;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
  .persona-rail a .arr {
    font-weight: 600;
    color: var(--color-text-muted);
    transition: transform var(--duration-fast) var(--easing-soft),
                color var(--duration-fast) var(--easing-soft);
    align-self: center;
  }
  .persona-rail a:hover .persona-num {
    background: var(--color-cta);
    color: var(--color-on-cta);
    border-color: var(--color-cta);
  }
  .persona-rail a:hover .persona-label {
    color: var(--color-cta);
  }
  .persona-rail a:hover .arr {
    transform: translateX(3px);
    color: var(--color-cta);
  }
  @media (hover: none) and (pointer: coarse) {
    .persona-rail a:hover .arr { transform: none; }
  }

  /* RESEARCH-AND-PROTOTYPES section — 50/50 layout: numbered pipeline
     steps on the left, sibling WebGL animation on the right. */
  .research-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    /* stretch (default) — the visual column matches the content
       column's height so the canvas is exactly as tall as the steps
       list on the left. */
    align-items: stretch;
  }
  @media (max-width: 900px) {
    .research-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  /* Tighter section-head spacing inside the grid — no need for the
     huge 3rem default since the meta is supporting the numbered
     list immediately below, not a wide grid of cards. */
  .research-head { margin-bottom: 2.25rem; }
  .research-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .research-step {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: 0.85rem;
    align-items: baseline;
  }
  .research-step-num {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-cta);
    line-height: 1;
  }
  .research-step-body { min-width: 0; }
  .research-step-body strong {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-primary);
    letter-spacing: -0.012em;
    display: block;
    margin-bottom: 0.2rem;
  }
  .research-step-body p {
    font-size: 14.5px;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  /* Visual half — hosts MarkDither. position: relative so the
     canvas (absolute, inset: 0) fills exactly this box. With the grid
     stretching, this column inherits the content column's height —
     no fixed aspect-ratio needed on desktop. */
  .research-visual {
    position: relative;
    background: var(--color-bg);
    min-height: 320px;
  }
  @media (max-width: 900px) {
    /* When the grid stacks, the visual loses its stretch reference
       (the content column is above it, not beside it). Give it an
       explicit aspect so it still has presence on tablet. */
    .research-visual { aspect-ratio: 16 / 9; min-height: 0; }
  }
  @media (max-width: 640px) {
    /* Hide the second WebGL canvas on phones — one shader is enough
       on a single page; drop the decorative one. */
    .research-visual { display: none; }
  }

  /* WRITEUPS — bigger image on top, text below. Three cards across on
     desktop to fit the three latest posts; collapses to single column
     on mobile. Image gets a 16:9 framing so the hero artwork actually
     reads, instead of the previous 104px square thumb. */
  .writeups {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 900px) { .writeups { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .writeups { grid-template-columns: 1fr; } }
  .writeup {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg);
    overflow: hidden;
    transition: transform var(--duration-base) var(--easing-soft),
                box-shadow var(--duration-base) var(--easing-soft),
                border-color var(--duration-base) var(--easing-soft);
    text-decoration: none;
    color: var(--color-text);
    box-shadow: var(--shadow-sm);
  }
  .writeup:hover {
    border-color: var(--color-cta);
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
  }
  .writeup-thumb {
    width: 100%;
    aspect-ratio: 16 / 9;
    position: relative;
    background: var(--color-bg-subtle);
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }
  .writeup-thumb img,
  .writeup-thumb svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--easing-soft);
  }
  .writeup:hover .writeup-thumb img,
  .writeup:hover .writeup-thumb svg { transform: scale(1.04); }
  .writeup-body { padding: 1rem 1.25rem 1.25rem; }
  .writeup-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .writeup-meta .pill {
    background: var(--color-bg-muted);
    color: var(--color-text-secondary);
    padding: 0.12rem 0.55rem;
    border-radius: 99px;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .writeup h4 {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1.1rem;
    line-height: 1.3;
    letter-spacing: -0.018em;
    margin-bottom: 0.4rem;
    color: var(--color-primary);
  }
  .writeup p {
    font-size: 13.5px;
    color: var(--color-text-secondary);
    line-height: 1.55;
  }
  .see-all-row {
    margin-top: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  /* Shares the mono/uppercase CTA style used by .home-faq-cta and
     .home-crops-cta so the three "see more" links on the homepage
     read as one component. */
  .see-all-row a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-cta);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .see-all-row a:hover { color: var(--color-cta-hover); }
  .see-all-row a .arr { transition: transform var(--duration-fast) var(--easing-soft); }
  .see-all-row a:hover .arr { transform: translateX(3px); }
  .see-all-row .cadence {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
  }

  @media (hover: none) and (pointer: coarse) {
    .writeup:hover { transform: none; }
  }

  /* CONTACT */
  .contact {
    padding: 10rem 0;
    background: linear-gradient(135deg, var(--color-bg-subtle) 0%, var(--color-bg) 60%);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 800px) { .contact-grid { grid-template-columns: 1fr; gap: 2rem; } }
  .contact h2 {
    font-family: var(--font-display);
    font-weight: 420;
    font-variation-settings: "opsz" 144, "SOFT" 0, "WONK" 0;
    font-size: clamp(2.15rem, 3.8vw, 3rem);
    line-height: 1.06;
    letter-spacing: -0.012em;
    color: var(--color-primary);
    max-width: 16ch;
    margin-bottom: 0.7rem;
  }
  .contact-body p {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 40ch;
    margin-bottom: 1.5rem;
  }
  .contact-options { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
  .contact-option {
    display: grid;
    grid-template-columns: 44px 1fr 18px;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.25rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color var(--duration-fast) var(--easing-soft),
                box-shadow var(--duration-fast) var(--easing-soft);
    box-shadow: var(--shadow-sm);
  }
  .contact-option:hover {
    border-color: var(--color-cta);
    box-shadow: var(--shadow-md);
  }
  .contact-option-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--color-bg-subtle);
    display: grid;
    place-items: center;
    color: var(--color-cta);
    flex-shrink: 0;
    transition: background var(--duration-fast) var(--easing-soft),
                color var(--duration-fast) var(--easing-soft);
  }
  .contact-option-icon :global(svg) { width: 20px; height: 20px; }
  .contact-option:hover .contact-option-icon { background: var(--color-primary); color: var(--color-on-primary); }
  .contact-option h4 {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    margin-bottom: 0.15rem;
    color: var(--color-primary);
    letter-spacing: -0.015em;
  }
  .contact-option p { font-size: 13px; color: var(--color-text-muted); line-height: 1.45; }
  .contact-option .arr {
    color: var(--color-text-muted);
    transition: transform var(--duration-fast) var(--easing-soft),
                color var(--duration-fast) var(--easing-soft);
    font-weight: 600;
  }
  .contact-option:hover .arr { color: var(--color-cta); transform: translateX(3px); }

  /* HOME FAQ teaser — paired with MarkDither on the right so
     the FAQ accordion column sits at ~58% of the container width and
     the diamond visual carries the rest. Animation hides on mobile so
     the FAQ takes full width again. */
  .home-faq {
    border-top: 1px solid var(--color-border);
  }
  .home-faq-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 4rem;
    /* `start` — the visual column stays at its intrinsic height so
       expanding a FAQ accordion doesn't restretch the canvas and
       resize the glyph mid-interaction. Vertical centring within
       the column happens via canvas geometry. */
    align-items: start;
  }
  @media (max-width: 960px) {
    .home-faq-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
  .home-faq-content { min-width: 0; }
  .home-faq-visual {
    position: relative;
    background: transparent;
    /* Square aspect ratio — the mark-dither SVG sits centered in a stable
       square so expanding a FAQ accordion never resizes the glyph. */
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    width: 100%;
  }
  @media (max-width: 960px) {
    /* On mobile, surface the animation above the headline as a small
       centred motif rather than hide it. `order` reorders the DOM
       columns into rows; -1 floats the visual to the top of the
       stacked grid. Width + aspect-ratio give it a fixed square so
       it doesn't dominate the section. */
    .home-faq-visual {
      order: -1;
      width: 180px;
      max-width: 60vw;
      aspect-ratio: 1 / 1;
      min-height: 0;
      margin: 0 auto 0.5rem;
    }
  }
  .home-faq-list {
    margin: 1.5rem 0 1.5rem;
    border-top: 1px solid var(--color-border);
  }
  .home-faq-item {
    border-bottom: 1px solid var(--color-border);
  }
  .home-faq-item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.2rem 0;
    color: var(--color-primary);
    transition: color var(--duration-fast) var(--easing-soft);
  }
  .home-faq-item summary::-webkit-details-marker { display: none; }
  .home-faq-item summary:hover { color: var(--color-cta); }
  .home-faq-q {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.4;
  }
  /* Plus / minus toggle drawn with two pseudo-elements; rotates 45deg
     when the details opens (matches /faq/). */
  .home-faq-toggle {
    position: relative;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform var(--duration-base) var(--easing-soft),
      color var(--duration-base) var(--easing-soft);
  }
  .home-faq-toggle::before,
  .home-faq-toggle::after {
    content: '';
    position: absolute;
    background: currentColor;
  }
  .home-faq-toggle::before {
    top: 50%; left: 0; right: 0; height: 2px;
    transform: translateY(-50%);
  }
  .home-faq-toggle::after {
    left: 50%; top: 0; bottom: 0; width: 2px;
    transform: translateX(-50%);
  }
  .home-faq-item[open] .home-faq-toggle {
    transform: rotate(45deg);
    color: var(--color-cta);
  }
  .home-faq-a {
    padding: 0 0 1.5rem;
    color: var(--color-text-secondary);
  }
  .home-faq-a p {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 0.85rem;
    color: var(--color-text);
  }
  .home-faq-a p:last-of-type { margin-bottom: 1rem; }
  .home-faq-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 0.5rem;
  }
  .home-faq-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-cta);
    text-decoration: none;
    padding: 5px 12px;
    border-radius: var(--radius-sm);
    background: var(--color-cta-tint);
    transition: background var(--duration-fast) var(--easing-soft),
      color var(--duration-fast) var(--easing-soft);
  }
  .home-faq-link:hover {
    background: var(--color-cta);
    color: var(--color-on-cta);
  }
  .home-faq-link svg { width: 12px; height: 12px; flex-shrink: 0; }
  .home-faq-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-cta);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .home-faq-cta:hover { color: var(--color-cta-hover); }
  .home-faq-cta .arr { transition: transform var(--duration-fast) var(--easing-soft); }
  .home-faq-cta:hover .arr { transform: translateX(3px); }

  /* HOME CROPS explainer */
  .home-crops {
    background: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .crops-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 1.5rem 0 2rem;
  }
  .crops-axis {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.25rem 1.1rem;
  }
  .crops-axis-code {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--color-cta);
    letter-spacing: 0.12em;
    margin-bottom: 0.5rem;
  }
  .crops-axis h3 {
    font-family: var(--font-sans);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-primary);
    margin: 0 0 0.45rem;
    letter-spacing: -0.018em;
    line-height: 1.25;
  }
