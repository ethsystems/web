---
/*
 * FAQ page — ported from ethsystems/web (`src/pages/faq.astro`,
 * test_guide branch).
 *
 * Content is a hand-written categories array — kept verbatim from
 * upstream. Restyled to our light theme + tokens. Accordion uses
 * native <details name=""> for mutually-exclusive open behavior,
 * dropping the fixed max-height JS pattern (project rule: never
 * use fixed sizes on collapsibles — let content drive height).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import { faqCategories } from '../data/faq';
import { faqPageSchema } from '../lib/schema';

const categories = faqCategories;

const pageDescription =
  'Curated from direct conversations with institutions evaluating privacy on Ethereum. Each answer links deeper into the guide.';
---

<BaseLayout
  title="FAQ"
  description={pageDescription}
  current="/faq/"
  structuredData={faqPageSchema(categories)}
>
  <PageHeader
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'FAQ' },
    ]}
    title="What institutions ask us most"
    lede={pageDescription}
  />

  <section class="faq">
    <div class="container">
      <div class="faq-inner">
      {categories.map((cat) => (
        <div class="faq-category">
          <div class="faq-cat-label">{cat.label}</div>
          {cat.questions.map((item, qIdx) => (
            <details class="faq-item" name="faq" open={cat === categories[0] && qIdx === 0}>
              <summary>
                <span class="faq-q">{item.q}</span>
                <span class="faq-toggle" aria-hidden="true"></span>
              </summary>
              <div class="faq-a">
                {item.a.map((p) => (
                  <p>{p}</p>
                ))}
                {item.links && item.links.length > 0 && (
                  <div class="faq-links">
                    {item.links.map((link) => (
                      <a href={link.href} class="faq-link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                          <path d="M5 12h14" />
                          <path d="M12 5l7 7-7 7" />
                        </svg>
                        {link.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
            </details>
          ))}
        </div>
      ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .faq {
    padding: 2rem 0 4rem;
  }
  .faq-inner {
    max-width: 800px;
    margin: 0;
    padding: 0;
  }

  .faq-category {
    margin-bottom: 2.5rem;
  }
  .faq-cat-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--color-text-muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 1.2rem 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-primary);
    transition: color var(--duration-fast) var(--easing-soft);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary:hover {
    color: var(--color-cta);
  }
  .faq-q {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.4;
  }
  /* Plus / minus toggle drawn from two pseudo-elements so we can
     animate the rotation cleanly when the details element opens. */
  .faq-toggle {
    position: relative;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform var(--duration-base) var(--easing-soft),
      color var(--duration-base) var(--easing-soft);
  }
  .faq-toggle::before,
  .faq-toggle::after {
    content: '';
    position: absolute;
    background: currentColor;
    transition: opacity var(--duration-fast) var(--easing-soft);
  }
  .faq-toggle::before {
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    transform: translateY(-50%);
  }
  .faq-toggle::after {
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    transform: translateX(-50%);
  }
  .faq-item[open] .faq-toggle {
    transform: rotate(45deg);
    color: var(--color-cta);
  }

  .faq-a {
    padding: 0 0 1.5rem;
    color: var(--color-text-secondary);
  }
  .faq-a p {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 0.85rem;
    color: var(--color-text);
  }
  .faq-a p:last-of-type { margin-bottom: 1rem; }

  .faq-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 0.5rem;
  }
  .faq-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-cta);
    text-decoration: none;
    padding: 5px 12px;
    border-radius: var(--radius-sm);
    background: var(--color-cta-tint);
    transition: background var(--duration-fast) var(--easing-soft),
      color var(--duration-fast) var(--easing-soft);
  }
  .faq-link:hover {
    background: var(--color-cta-tint-strong);
    color: var(--color-cta-hover);
  }
  .faq-link svg {
    width: 10px;
    height: 10px;
  }
</style>
